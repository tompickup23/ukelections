  "boundary_changes": [
    {"year": 1885, "note": "Created as Lancashire (South-West), Ince Division. Wards: Abram, Haigh, Hindley, Ince-in-Makerfield, Orrell, Pemberton."},
    {"year": 1918, "note": "Reorganised: Abram, Ashton in Makerfield, Billinge, Ince-in-Makerfield, Orrell, Standish with Langtree UDs + Shevington civil parish."},
    {"year": 1950, "note": "Renamed Ince County Constituency: Abram, Ashton in Makerfield, Billinge & Winstanley, Ince-in-Makerfield, Orrell, Skelmersdale, Upholland UDs."},
    {"year": 1970, "note": "Renamed Ince Borough Constituency: six UDs (Abram, Ashton in Makerfield, Billinge & Winstanley, Ince-in-Makerfield, Orrell, Skelmersdale & Holland)."},
    {"year": 1983, "note": "Abolished by Parliamentary Constituencies (England) Order 1983. Split into Makerfield (most), St Helens North, West Lancashire, and Wigan."}
  ],
  "notable_mps": [
    {"name": "Stephen Walsh", "tenure": "1906-1929", "note": "Labour pioneer; held seat 23 years from breakthrough 1906 win."},
    {"name": "Gordon Macdonald", "tenure": "1929-1942", "note": "Later became Lord Macdonald of Gwaenysgor."},
    {"name": "Tom Brown", "tenure": "1942-1964", "note": "22-year tenure spanning Attlee, Churchill, Eden, Macmillan governments."},
    {"name": "Michael McGuire", "tenure": "1964-1983 (Ince) then 1983-1987 (Makerfield)", "note": "Held both Ince and successor Makerfield until 1987; 23 years total Labour service."}
