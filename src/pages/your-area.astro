---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Your Area" description="Postcode and place lookup plan for routing voters to the right UK election contest.">
  <section class="page-hero">
    <p class="eyebrow">Your Area</p>
    <h1>Lookup starts with the right contest.</h1>
    <p class="lede">
      The live version will accept a postcode or place name, resolve it to the right seat or contest,
      and show what is known, what is estimated, and what is still missing.
    </p>
  </section>

  <section class="lookup-shell" aria-label="Lookup placeholder">
    <form class="lookup-form">
      <label for="postcode">Postcode or place</label>
      <div>
        <input id="postcode" name="postcode" type="search" placeholder="e.g. SW1A 1AA" disabled />
        <button type="button" disabled>Lookup coming soon</button>
      </div>
      <p>The input is disabled until the boundary lookup and source cache are wired.</p>
    </form>
  </section>
</BaseLayout>
