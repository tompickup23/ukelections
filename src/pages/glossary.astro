---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Term {
  term: string;
  slug: string;
  definition: string;
}

const terms: Term[] = [
  { term: "Asylum seeker", slug: "asylum-seeker", definition: "A person who has applied for refugee status and is waiting for a decision. They have not been granted permission to stay. They are not allowed to work. The Home Office houses and supports them while their claim is processed." },
  { term: "Refugee", slug: "refugee", definition: "A person whose asylum claim has been granted. They have legal permission to stay in the UK, can work, and can access public services. The terms 'asylum seeker' and 'refugee' are not interchangeable." },
  { term: "Migrant", slug: "migrant", definition: "Anyone who moves from one country to another. This includes students, workers, family members, and asylum seekers. It is not a legal status. Using 'migrant' and 'asylum seeker' interchangeably is inaccurate." },
  { term: "Dispersal accommodation", slug: "dispersal-accommodation", definition: "Housing provided by the Home Office to asylum seekers outside London and the South East. Typically flats or houses in areas with lower housing costs. Managed by private contractors (Serco, Mears, Clearsprings)." },
  { term: "Contingency accommodation", slug: "contingency-accommodation", definition: "Temporary housing used when dispersal accommodation is full. Usually hotels, hostels, or former military barracks. More expensive per person than dispersal housing. Not intended to be long-term." },
  { term: "Initial accommodation", slug: "initial-accommodation", definition: "Short-term housing for new asylum seekers while their support application is processed. Typically large hostel-style sites. People are supposed to stay for a few weeks but backlogs mean some stay months." },
  { term: "Subsistence only", slug: "subsistence-only", definition: "Asylum seekers who receive financial support but arrange their own accommodation, usually staying with friends or family. They get a cash allowance but no housing from the Home Office." },
  { term: "Section 95 support", slug: "section-95", definition: "The main form of asylum support, named after Section 95 of the Immigration and Asylum Act 1999. Covers accommodation and/or subsistence for destitute asylum seekers while their claim is being considered." },
  { term: "Section 98 support", slug: "section-98", definition: "Emergency support for asylum seekers who appear destitute and need immediate accommodation. Temporary, pending a full Section 95 assessment." },
  { term: "Decision backlog", slug: "decision-backlog", definition: "The number of asylum claims awaiting an initial decision from the Home Office. Each person in the backlog costs the taxpayer roughly £150 per day in accommodation and support while they wait." },
  { term: "Grant rate", slug: "grant-rate", definition: "The percentage of asylum claims that are approved (granted refugee status or humanitarian protection) at initial decision. Varies enormously by nationality." },
  { term: "Small boats", slug: "small-boats", definition: "Irregular Channel crossings in small vessels, typically inflatable dinghies. The dominant route for illegal entry into the UK since 2020. Crossings are coordinated by organised criminal gangs." },
  { term: "Safe and legal routes", slug: "safe-and-legal-routes", definition: "Official pathways for refugees to enter the UK without making an irregular journey. Includes the UK Resettlement Scheme, Afghan schemes (ARAP/ACRS), and Homes for Ukraine." },
  { term: "Homes for Ukraine", slug: "homes-for-ukraine", definition: "A visa scheme launched in March 2022 allowing UK residents to sponsor Ukrainian nationals fleeing the war. Sponsors provide accommodation for at least six months. Distinct from the asylum system." },
  { term: "Afghan programme", slug: "afghan-programme", definition: "Two schemes: ARAP (Afghan Relocations and Assistance Policy) for interpreters and staff who worked with UK forces, and ACRS (Afghan Citizens Resettlement Scheme) for vulnerable Afghans. Some remain in bridging hotels years later." },
  { term: "White British Index", slug: "white-british-index", definition: "The percentage of a local authority's population identifying as White British in the Census. Used in demographic projections to track compositional change over time. Not a value judgement. A statistical measure." },
  { term: "Shift-share decomposition", slug: "shift-share", definition: "A statistical method that separates demographic change into three components: the national trend (happening everywhere), the structural effect (age/composition), and the local effect (specific to that area). Shows what is driving change in each place." },
  { term: "Hamilton-Perry method", slug: "hamilton-perry", definition: "A demographic projection technique that uses the ratio of population change between two census periods to project forward. Simpler than cohort-component models. Does not require fertility/mortality/migration estimates." },
  { term: "Pressure index", slug: "pressure-index", definition: "A composite score combining five domains: asylum dispersal rate, demographic change speed, police recorded crime, SEND demand growth, and adult social care spend. Higher scores indicate areas under more combined pressure." },
  { term: "SEND", slug: "send", definition: "Special Educational Needs and Disabilities. Measured by the number of Education, Health and Care Plans (EHCPs) issued by a local authority. Demand has grown significantly in areas with rapid population change." },
  { term: "Adult social care (ASC)", slug: "asc", definition: "Services provided by councils for adults who need help with daily living due to illness, disability, or old age. Includes home care, residential care, and day services. One of the largest areas of council spending." },
  { term: "IMD", slug: "imd", definition: "Index of Multiple Deprivation. The government's official measure of how deprived an area is, combining income, employment, education, health, crime, housing, and environment. Rank 1 is the most deprived." },
  { term: "Prime provider", slug: "prime-provider", definition: "The main contractor responsible for asylum accommodation in a region. Three companies hold these contracts: Serco, Mears Group, and Clearsprings Ready Homes. They subcontract to local landlords and hotel operators." },
  { term: "UKVI", slug: "ukvi", definition: "UK Visas and Immigration. The Home Office division that processes asylum claims, visa applications, and immigration decisions." },
  { term: "NAO", slug: "nao", definition: "National Audit Office. The independent body that scrutinises public spending on behalf of Parliament. Their reports on asylum accommodation costs are a primary source for this site." },
  { term: "Home Office", slug: "home-office", definition: "The government department responsible for immigration, asylum, policing, and national security. Makes all decisions on asylum claims and manages the asylum support system through contractors." }
];
---

<BaseLayout
  title="Glossary - UK Demographics"
  description="Plain-English definitions of every term used on ukdemographics.co.uk. Asylum seeker, refugee, dispersal, SEND, and more."
>
  <section class="glossary-page shell">
    <h1>Glossary</h1>
    <p class="glossary-intro">
      Plain English. No jargon. Every term used on this site, defined.
    </p>

    <div class="glossary-list">
      {terms.map((t) => (
        <div class="glossary-entry" id={t.slug}>
          <h2 class="glossary-term-title">{t.term}</h2>
          <p class="glossary-definition">{t.definition}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .glossary-page {
    padding-top: 2.5rem;
    padding-bottom: 3rem;
    max-width: 720px;
  }
  .glossary-page h1 {
    font-family: "Sora", sans-serif;
    font-size: 2rem;
    font-weight: 800;
    margin: 0;
  }
  .glossary-intro {
    color: var(--muted);
    font-size: 0.95rem;
    margin: 0.5rem 0 2rem;
  }
  .glossary-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .glossary-entry {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
    scroll-margin-top: 80px;
  }
  .glossary-entry:target {
    background: rgba(6, 182, 212, 0.06);
    border-radius: var(--radius-sm);
    padding: 1.25rem;
    margin: 0 -1.25rem;
    border-bottom-color: transparent;
  }
  .glossary-term-title {
    font-family: "Sora", sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent);
    margin: 0 0 0.35rem;
  }
  .glossary-definition {
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--ink-soft);
    margin: 0;
  }
</style>
