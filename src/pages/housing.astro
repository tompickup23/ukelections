---
import BaseLayout from "../layouts/BaseLayout.astro";
import { slugifyAreaName } from "../lib/site";
import housingDemand from "../data/live/housing-demand.json";

const hd = housingDemand as any;
const areasWithData = Object.entries(hd.areas)
  .filter(([_, d]: any) => d.dataAvailable)
  .map(([code, d]: any) => ({ code, ...d }))
  .sort((a, b) => (b.socialRentChangePp ?? 0) - (a.socialRentChangePp ?? 0));

const risingDemand = areasWithData.filter(a => (a.socialRentChangePp ?? 0) > 0).length;
---

<BaseLayout
  title="Housing demand projections"
  description={`Housing tenure projections for ${areasWithData.length} local authorities. Census 2021 tenure patterns by ethnicity × population projections.`}
>
  <h1>Housing demand projections</h1>
  <p class="desc">Census 2021 tenure patterns (ownership, social rent, private rent) by ethnic group, projected forward using demographic composition changes. {areasWithData.length} areas.</p>

  <div class="stats-grid">
    <div class="stat-card"><span class="stat-value" style="color:var(--accent)">{areasWithData.length}</span><span class="stat-label">Areas modelled</span></div>
    <div class="stat-card"><span class="stat-value" style="color:var(--coral)">{risingDemand}</span><span class="stat-label">Areas with rising social rent demand</span></div>
  </div>

  <div class="area-table">
    <div class="area-table-header"><span>Area</span><span>Owner 2021</span><span>Social 2021</span><span>Social 2041</span><span>Change</span></div>
    {areasWithData.slice(0, 50).map((a) => (
      <a href={`/places/${slugifyAreaName(a.areaName)}/`} class="area-row">
        <span class="name">{a.areaName}</span>
        <span class="val">{a.currentTenure?.ownershipPct?.toFixed(1) ?? "-"}%</span>
        <span class="val">{a.currentTenure?.socialRentPct?.toFixed(1) ?? "-"}%</span>
        <span class="val accent">{a.projectedTenure2041?.socialRentPct?.toFixed(1) ?? "-"}%</span>
        <span class="val" style={`color: ${(a.socialRentChangePp ?? 0) > 0 ? 'var(--coral)' : 'var(--accent-2)'}`}>{a.socialRentChangePp != null ? `${a.socialRentChangePp > 0 ? '+' : ''}${a.socialRentChangePp.toFixed(1)}pp` : "-"}</span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  h1 { font-family: "Sora", sans-serif; font-size: 1.8rem; font-weight: 800; margin: 0 0 0.5rem; }
  .desc { color: var(--muted); font-size: 0.92rem; margin: 0 0 1.5rem; max-width: 700px; }
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0.75rem; margin-bottom: 2rem; }
  .stat-card { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 1.25rem; display: flex; flex-direction: column; gap: 0.2rem; }
  .stat-value { font-family: "Sora", sans-serif; font-size: 1.75rem; font-weight: 800; line-height: 1; }
  .stat-label { font-size: 0.85rem; color: var(--muted); }
  .area-table { max-width: 800px; }
  .area-table-header { display: grid; grid-template-columns: 1fr 80px 80px 80px 70px; padding: 0.5rem 0.75rem; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); border-bottom: 1px solid var(--border-strong); }
  .area-row { display: grid; grid-template-columns: 1fr 80px 80px 80px 70px; align-items: center; padding: 0.5rem 0.75rem; text-decoration: none; color: var(--ink); border-bottom: 1px solid var(--border); transition: background 120ms; }
  .area-row:hover { background: rgba(79, 70, 229, 0.06); }
  .name { font-weight: 600; font-size: 0.88rem; }
  .val { font-family: "Sora", sans-serif; font-size: 0.85rem; font-weight: 700; color: var(--ink); }
  .val.accent { color: var(--accent); }
</style>
