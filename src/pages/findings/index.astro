---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allContent = (await getCollection("findings")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const articles = allContent.filter((f) => f.data.content_type === "article");
const findings = allContent.filter((f) => f.data.content_type !== "article");

const verdictColor: Record<string, string> = {
  alert: "var(--accent-3)",
  critical: "#ef4444",
  resolved: "#10b981",
  info: "var(--accent)"
};

const verdictLabel: Record<string, string> = {
  alert: "Finding",
  critical: "Investigation",
  resolved: "Resolved",
  info: "Analysis"
};

const categoryLabel: Record<string, string> = {
  spending: "Spending",
  routes: "Routes",
  demographics: "Demographics",
  backlog: "Backlog",
  accountability: "Accountability",
  crime: "Crime",
  "pressure-index": "Pressure",
  "social-care": "Social care",
  send: "Schools"
};
---

<BaseLayout
  title="Research - UK Demographics"
  description="Articles and findings on UK asylum costs, demographic change, and the system. Every number sourced. No spin."
>
  <section class="findings-header shell">
    <h1>Research</h1>
    <p class="findings-intro">
      Articles backed by data. Findings verified against source.
      Scrutinise the methodology. Check the sources. Draw your own conclusions.
    </p>
  </section>

  <!-- ARTICLES (long-form) -->
  {articles.length > 0 && (
    <section class="articles-section shell">
      <h2 class="section-label">Articles</h2>
      <div class="articles-list">
        {articles.map((article) => (
          <a href={`/findings/${article.id.replace(/\.md$/, "")}/`} class="article-hero-card">
            <div class="article-hero-meta">
              <span class="article-type-badge">Article</span>
              <span class="article-category">{categoryLabel[article.data.category] ?? article.data.category}</span>
              <span class="article-date">{article.data.date}</span>
            </div>
            <h2 class="article-hero-headline">{article.data.headline}</h2>
            <div class="article-hero-stat">
              <span class="article-stat-value" style={`color: ${verdictColor[article.data.verdict]}`}>
                {article.data.stat_value}
              </span>
              <span class="article-stat-label">{article.data.stat_label}</span>
            </div>
            <p class="article-hero-summary">{article.data.summary}</p>
            <span class="article-hero-cta">Read the full article &rarr;</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- FINDINGS (stat cards) -->
  <section class="findings-section shell">
    <h2 class="section-label">Findings</h2>
    <div class="findings-grid">
      {findings.map((finding) => (
        <a href={`/findings/${finding.id.replace(/\.md$/, "")}/`} class="finding-card">
          <div class="finding-meta">
            <span class="finding-category">{categoryLabel[finding.data.category] ?? finding.data.category}</span>
            <span class="finding-date">{finding.data.date}</span>
          </div>
          <h3 class="finding-headline">{finding.data.headline}</h3>
          <div class="finding-stat-row">
            <span class="finding-stat" style={`color: ${verdictColor[finding.data.verdict]}`}>
              {finding.data.stat_value}
            </span>
            <span class="finding-stat-label">{finding.data.stat_label}</span>
          </div>
          <p class="finding-summary">{finding.data.summary}</p>
          <span class="finding-source">{finding.data.source_label} &rarr;</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .findings-header {
    padding-top: 2.5rem;
  }
  .findings-header h1 {
    font-family: "Sora", sans-serif;
    font-size: 2rem;
    font-weight: 800;
    margin: 0;
  }
  .findings-intro {
    color: var(--muted);
    font-size: 0.95rem;
    max-width: 550px;
    margin: 0.5rem 0 0;
  }

  .section-label {
    font-family: "Sora", sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin: 0 0 1rem;
  }

  /* ARTICLES */
  .articles-section {
    margin-top: 2rem;
  }
  .articles-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .article-hero-card {
    background: var(--panel-strong);
    border: 1px solid var(--border);
    border-left: 3px solid var(--coral);
    border-radius: var(--radius-sm);
    padding: 2rem;
    text-decoration: none;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 180ms, transform 120ms;
  }
  .article-hero-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .article-hero-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .article-type-badge {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--coral);
    background: rgba(239, 68, 68, 0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
  }
  .article-category {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    background: rgba(125, 211, 252, 0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
  }
  .article-date {
    font-size: 0.78rem;
    color: var(--muted);
  }
  .article-hero-headline {
    font-family: "Sora", sans-serif;
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    font-weight: 800;
    line-height: 1.2;
    margin: 0;
    letter-spacing: -0.02em;
  }
  .article-hero-stat {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .article-stat-value {
    font-family: "Sora", sans-serif;
    font-size: 2.2rem;
    font-weight: 800;
    line-height: 1;
  }
  .article-stat-label {
    font-size: 0.88rem;
    color: var(--muted);
  }
  .article-hero-summary {
    font-size: 0.92rem;
    color: var(--ink-soft);
    line-height: 1.6;
    margin: 0;
  }
  .article-hero-cta {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--accent);
    margin-top: auto;
  }

  /* FINDINGS */
  .findings-section {
    margin-top: 2.5rem;
    padding-bottom: 3rem;
  }
  .findings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1rem;
  }
  .finding-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 1.5rem;
    text-decoration: none;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    transition: border-color 180ms, transform 120ms;
  }
  .finding-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .finding-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .finding-category {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    background: rgba(125, 211, 252, 0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
  }
  .finding-date {
    font-size: 0.78rem;
    color: var(--muted);
  }
  .finding-headline {
    font-family: "Sora", sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }
  .finding-stat-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .finding-stat {
    font-family: "Sora", sans-serif;
    font-size: 1.6rem;
    font-weight: 800;
    line-height: 1;
  }
  .finding-stat-label {
    font-size: 0.78rem;
    color: var(--muted);
  }
  .finding-summary {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .finding-source {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent);
    margin-top: auto;
  }

  @media (max-width: 640px) {
    .article-hero-card { padding: 1.25rem; }
    .article-stat-value { font-size: 1.6rem; }
    .findings-grid { grid-template-columns: 1fr; }
  }
</style>
