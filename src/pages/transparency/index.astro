---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadGePredictions, loadGeSummary, loadGeAssumptions, loadGeIdentity } from "../../lib/predictions";

const ge = loadGePredictions();
const summary = loadGeSummary();
const assumptions = loadGeAssumptions();
const identity = loadGeIdentity();
---

<BaseLayout
  title="Transparency &amp; pre-registration"
  description="Pre-registered, sha256-committed forecast manifests. Every weight, dampening, and source is auditable."
>
  <section class="page-hero">
    <p class="eyebrow">Transparency</p>
    <h1>Pre-registration &amp; audit log</h1>
    <p class="lede">
      Every forecast is sha256-committed before publication. Every assumption is machine-readable and version-controlled. Every input source is timestamped.
    </p>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Latest forecast manifest</p>
      <h2>General election — next-GE-as-if-held-this-week</h2>
    </div>
    <table class="seat-table">
      <thead><tr><th>File</th><th>Snapshot ID</th><th>Generated at</th></tr></thead>
      <tbody>
        <tr>
          <td><code>data/predictions/ge-next/constituencies.json</code></td>
          <td><code>{ge.snapshot?.snapshot_id}</code></td>
          <td>{ge.snapshot?.generated_at?.slice(0, 19).replace("T", " ")}</td>
        </tr>
        <tr>
          <td><code>data/predictions/ge-next/summary.json</code></td>
          <td><code>{summary.snapshot?.snapshot_id}</code></td>
          <td>{summary.snapshot?.generated_at?.slice(0, 19).replace("T", " ")}</td>
        </tr>
        <tr>
          <td><code>data/predictions/ge-next/assumptions.json</code></td>
          <td><code>{assumptions.snapshot?.snapshot_id}</code></td>
          <td>{assumptions.snapshot?.generated_at?.slice(0, 19).replace("T", " ")}</td>
        </tr>
        <tr>
          <td><code>data/identity/pcons-ge-next.json</code></td>
          <td><code>{identity.snapshot?.snapshot_id}</code></td>
          <td>{identity.snapshot?.generated_at?.slice(0, 19).replace("T", " ")}</td>
        </tr>
      </tbody>
    </table>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Sources</p>
      <h2>What feeds each forecast</h2>
    </div>
    <ul>
      {(summary.snapshot?.sources || []).map((src: any) => (
        <li><code>{src.path}</code> — {src.role}</li>
      ))}
    </ul>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Assumptions</p>
      <h2>Every parameter, machine-readable</h2>
    </div>
    <pre style="white-space: pre-wrap; background: var(--card); padding: 1rem;">{JSON.stringify(assumptions.parameters, null, 2)}</pre>
    <p style="color: var(--muted)">
      Download the raw JSON: <a href="/data/predictions/ge-next/assumptions.json">assumptions.json</a>
    </p>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Coverage</p>
      <h2>Identity-table coverage</h2>
    </div>
    <ul>
      <li>Total PCONs: {identity.snapshot?.coverage?.total}</li>
      <li>With PCON24CD GSS: {identity.snapshot?.coverage?.with_pcon24cd}</li>
      <li>With region: {identity.snapshot?.coverage?.with_region}</li>
      <li>By country: {Object.entries(identity.snapshot?.coverage?.by_country || {}).map(([k, v]) => `${k}: ${v}`).join(" · ")}</li>
    </ul>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Standard</p>
      <h2>What &quot;audit-grade&quot; means</h2>
    </div>
    <ol>
      <li><strong>Pre-registration</strong> — every forecast file's sha256 is computed and recorded before publication; subsequent edits produce a new snapshot ID.</li>
      <li><strong>Source manifest</strong> — every input file lists path, retrieved-at timestamp, and licence.</li>
      <li><strong>Machine-readable assumptions</strong> — every weight, dampening, ceiling, and threshold lives in <code>assumptions.json</code> so any third party can replicate or stress-test by tweaking one value at a time.</li>
      <li><strong>Open data</strong> — all prediction JSON files downloadable directly from the site under CC-BY.</li>
      <li><strong>Open methodology</strong> — every prediction page shows the full methodology trace; the model code lives at <code>src/lib/electionModel.js</code>.</li>
    </ol>
    <p style="color: var(--muted)">
      Targets: Royal Statistical Society Code of Practice for forecasters · British Polling Council membership criteria.
    </p>
  </section>
</BaseLayout>
