---
import BaseLayout from "../layouts/BaseLayout.astro";
import { slugifyAreaName } from "../lib/site";
import fiscalResilience from "../data/live/fiscal-resilience.json";

const fr = fiscalResilience as any;
const ranked = Object.entries(fr.areas)
  .map(([code, d]: any) => ({ code, ...d }))
  .sort((a, b) => b.serviceDemandPressureScore - a.serviceDemandPressureScore);

const high = ranked.filter(a => a.category === 'High Pressure');
const moderate = ranked.filter(a => a.category === 'Moderate Pressure');
---

<BaseLayout
  title="Service demand pressure index"
  description={`Service demand pressure scoring for ${ranked.length} local authorities. ${high.length} areas rated high pressure from demographic change.`}
>
  <h1>Service demand pressure index</h1>
  <p class="desc">Composite score (0-100) from 5 components: ethnic change rate, asylum concentration, school diversity, language demand, and housing pressure. Higher = more service demand from demographic change.</p>

  <div class="stats-grid">
    <div class="stat-card"><span class="stat-value" style="color:var(--coral)">{high.length}</span><span class="stat-label">High pressure</span></div>
    <div class="stat-card"><span class="stat-value" style="color:var(--accent-3)">{moderate.length}</span><span class="stat-label">Moderate pressure</span></div>
    <div class="stat-card"><span class="stat-value" style="color:var(--accent-2)">{ranked.length - high.length - moderate.length}</span><span class="stat-label">Low / Stable</span></div>
  </div>

  <h2 class="section-title">Top 30 — highest service demand pressure</h2>
  <div class="area-table">
    <div class="area-table-header"><span>#</span><span>Area</span><span>Score</span><span>Category</span><span>WBI change</span></div>
    {ranked.slice(0, 30).map((a, i) => (
      <a href={`/places/${slugifyAreaName(a.areaName)}/`} class="area-row">
        <span class="rank">{i + 1}</span>
        <span class="name">{a.areaName}</span>
        <span class="score" style={`color: ${a.serviceDemandPressureScore >= 70 ? 'var(--coral)' : a.serviceDemandPressureScore >= 45 ? 'var(--accent-3)' : 'var(--accent)'}`}>{a.serviceDemandPressureScore}</span>
        <span class="category">{a.category}</span>
        <span class="change" style={`color: ${a.wbiChange2021to2041 < -10 ? 'var(--coral)' : 'var(--muted)'}`}>{a.wbiChange2021to2041 > 0 ? '+' : ''}{a.wbiChange2021to2041}pp</span>
      </a>
    ))}
  </div>

  <h2 class="section-title" style="margin-top: 2.5rem;">Score components</h2>
  <p class="desc">Each component contributes up to 20 points to the total score.</p>
  <div class="component-grid">
    <div class="component-card">
      <span class="component-name">Ethnic change rate</span>
      <span class="component-desc">Speed of WBI composition change 2021-2041</span>
    </div>
    <div class="component-card">
      <span class="component-name">Asylum concentration</span>
      <span class="component-desc">Asylum support rate per 10,000 population</span>
    </div>
    <div class="component-card">
      <span class="component-name">School diversity pressure</span>
      <span class="component-desc">Projected EAL demand growth from DfE data</span>
    </div>
    <div class="component-card">
      <span class="component-name">Language demand</span>
      <span class="component-desc">Projected non-English speaking population growth</span>
    </div>
    <div class="component-card">
      <span class="component-name">Housing pressure</span>
      <span class="component-desc">Foreign-born population growth driving housing demand</span>
    </div>
  </div>
</BaseLayout>

<style>
  h1 { font-family: "Sora", sans-serif; font-size: 1.8rem; font-weight: 800; margin: 0 0 0.5rem; }
  .desc { color: var(--muted); font-size: 0.92rem; margin: 0 0 1.5rem; max-width: 700px; }
  .section-title { font-family: "Sora", sans-serif; font-size: 1.15rem; font-weight: 800; margin: 0 0 0.75rem; }
  .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-bottom: 2rem; }
  .stat-card { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 1.25rem; display: flex; flex-direction: column; gap: 0.2rem; }
  .stat-value { font-family: "Sora", sans-serif; font-size: 1.75rem; font-weight: 800; line-height: 1; }
  .stat-label { font-size: 0.85rem; color: var(--muted); }
  .area-table { max-width: 800px; }
  .area-table-header { display: grid; grid-template-columns: 32px 1fr 60px 120px 80px; padding: 0.5rem 0.75rem; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); border-bottom: 1px solid var(--border-strong); }
  .area-row { display: grid; grid-template-columns: 32px 1fr 60px 120px 80px; align-items: center; padding: 0.5rem 0.75rem; text-decoration: none; color: var(--ink); border-bottom: 1px solid var(--border); transition: background 120ms; }
  .area-row:hover { background: rgba(79, 70, 229, 0.06); }
  .rank { font-size: 0.82rem; color: var(--muted); font-weight: 700; }
  .name { font-weight: 600; font-size: 0.88rem; }
  .score { font-family: "Sora", sans-serif; font-size: 1rem; font-weight: 800; }
  .category { font-size: 0.78rem; color: var(--muted); }
  .change { font-family: "Sora", sans-serif; font-size: 0.85rem; font-weight: 700; }
  .component-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0.75rem; }
  .component-card { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 1rem; }
  .component-name { display: block; font-weight: 700; font-size: 0.92rem; color: var(--ink); margin-bottom: 0.25rem; }
  .component-desc { font-size: 0.82rem; color: var(--muted); }
  @media (max-width: 640px) { .stats-grid { grid-template-columns: 1fr; } .area-table-header, .area-row { grid-template-columns: 28px 1fr 50px 80px; } .category { display: none; } }
</style>
