---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { loadGePredictions, partyColour } from "../../../lib/predictions";
import { loadGeHeadline, shortPartyLabel } from "../../../lib/siteData";

const ge = loadGePredictions();
const headline = loadGeHeadline();

const predictions = ge.predictions || {};
const evaluated = Object.values(predictions).filter((p: any) => p?.prediction);
const marginals = evaluated
  .filter((p: any) => p?.majority_pct != null)
  .sort((a: any, b: any) => Math.abs(a.majority_pct) - Math.abs(b.majority_pct))
  .slice(0, 50);

const top = headline.seat_tallies[0];
const second = headline.seat_tallies[1];
const HALFWAY = 326;
---

<BaseLayout
  title="General election forecast — every UK constituency"
  description={`Forecast for all ${headline.total_seats} UK constituencies if a general election were held today. Headline: ${top ? `${shortPartyLabel(top.party)} ${top.seats}` : "no clear lead"}.`}
>
  <section class="page-hero">
    <p class="eyebrow">If a UK general election were held today</p>
    <h1>{top ? `${shortPartyLabel(top.party)} projected to win ${top.seats} seats` : "Every UK constituency, forecast"}</h1>
    <p class="lede">
      All {headline.total_seats.toLocaleString()} UK parliamentary constituencies. Refreshed daily from the latest UK Westminster polling.
      A majority needs <strong>{HALFWAY}</strong> seats. {top && top.seats >= HALFWAY ? `${shortPartyLabel(top.party)} clears the line; ${(top.seats - HALFWAY).toLocaleString()} seats above the majority threshold.` : `${top ? shortPartyLabel(top.party) : "The leading party"} is ${top ? Math.abs(HALFWAY - top.seats).toLocaleString() : "—"} short of an overall majority.`}
    </p>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Seats projection</p>
      <h2>How the new House of Commons would look</h2>
    </div>
    <div class="party-bars party-bars-large">
      {headline.seat_tallies.map((t) => (
        <div class="bar-row">
          <span class="bar-label">{shortPartyLabel(t.party)}</span>
          <div class="bar-track">
            <div class="bar-fill" style={`width:${(t.share * 100).toFixed(1)}%; background:${partyColour(t.party)}`}></div>
          </div>
          <span class="bar-value">{t.seats.toLocaleString()} <span class="bar-share">({(t.share * 100).toFixed(1)}%)</span></span>
        </div>
      ))}
    </div>
    {top && second && (
      <p class="caption">
        That's a {(top.seats - second.seats).toLocaleString()}-seat lead for {shortPartyLabel(top.party)} over {shortPartyLabel(second.party)}.
      </p>
    )}
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Vote share</p>
      <h2>What share of the national vote each party would get</h2>
    </div>
    <div class="party-bars">
      {headline.national_vote_share.slice(0, 8).map((t) => (
        <div class="bar-row">
          <span class="bar-label">{shortPartyLabel(t.party)}</span>
          <div class="bar-track">
            <div class="bar-fill" style={`width:${(t.share * 100).toFixed(1)}%; background:${partyColour(t.party)}`}></div>
          </div>
          <span class="bar-value">{(t.share * 100).toFixed(1)}%</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Tightest contests</p>
      <h2>Top 50 marginals</h2>
    </div>
    <p class="caption">
      The closest predicted contests on this forecast — these are the seats most likely to flip if the polling moves.
    </p>
    <table class="seat-table">
      <thead><tr><th>Constituency</th><th>Predicted winner</th><th>Margin</th><th>Country</th></tr></thead>
      <tbody>
        {marginals.map((m: any) => (
          <tr>
            <td><a href={`/seats/parliament/${m.slug}/`}>{m.name}</a></td>
            <td><span class="party-swatch" style={`background:${partyColour(m.winner)}`}></span> {shortPartyLabel(m.winner)}</td>
            <td class="num">{((m.majority_pct ?? 0) * 100).toFixed(1)}pp</td>
            <td>{m.country?.replace(/_/g, " ")}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">How accurate</p>
      <h2>Tested against the actual 2024 general election</h2>
    </div>
    <p>
      We replayed the same model against the real 2024 general election using only what a forecaster running the model
      in May 2024 would have known. The model called the winner correctly in
      <strong>{(headline.backtest_winner_accuracy * 100).toFixed(1)}%</strong> of constituencies, with an average gap of
      <strong>{(headline.backtest_major_party_mae * 100).toFixed(2)}pp</strong> between predicted and actual party share.
    </p>
    <p>
      <a href="/data-quality/ge-backtest/">Full accuracy record →</a>
    </p>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Caveats</p>
      <h2>What this forecast does and doesn't try to do</h2>
    </div>
    <ul class="plain-list">
      <li><strong>It assumes a notional election held this week</strong>, using current Westminster polling. The next general election may be months or years away — the forecast will move with the polls.</li>
      <li><strong>It does not predict turnout swings</strong> or campaign effects beyond what's already reflected in the polls. Late-campaign movement can be substantial.</li>
      <li><strong>It does not assume tactical voting beyond the pattern observed in 2024.</strong> A formal pact between Labour and the Liberal Democrats, for example, is not modelled.</li>
      <li><strong>Confidence intervals are not yet shown per seat.</strong> A future release will publish a high–low band on each constituency.</li>
    </ul>
    <p class="caption">
      Read about the model and how it's tested at <a href="/methodology/">About</a>.
    </p>
  </section>
</BaseLayout>
