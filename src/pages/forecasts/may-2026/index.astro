---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { loadSummary, partyColour } from "../../../lib/predictions";
import { loadMayHeadline, countdownToMay, shortPartyLabel } from "../../../lib/siteData";

const summary = loadSummary();
const headline = loadMayHeadline();
const cd = countdownToMay();

const localCouncils = summary.councils
  .filter((c: any) => c.tier === "local")
  .sort((a: any, b: any) => a.council_name.localeCompare(b.council_name));
const mayorCouncils = summary.councils
  .filter((c: any) => c.tier === "mayor")
  .sort((a: any, b: any) => a.council_name.localeCompare(b.council_name));

const topParty = headline.seat_tallies[0];
---

<BaseLayout
  title="May 7 election forecast — every English council, Senedd, and Holyrood"
  description={`${headline.seats_total.toLocaleString()} seats are up on May 7 2026 across ${headline.council_count} English councils plus the Senedd and the Scottish Parliament. ${cd.has_passed ? "Live tracking." : `${cd.days_until} days to go.`}`}
>
  <section class="page-hero">
    <p class="eyebrow">{cd.has_passed ? "Live tracking" : `${cd.days_until} days to go · ${cd.date_pretty}`}</p>
    <h1>May 7 — every contested seat</h1>
    <p class="lede">
      {headline.council_count} English councils, the Senedd Cymru, and the Scottish Parliament.
      {headline.ward_count.toLocaleString()} wards or constituencies. {headline.candidate_count.toLocaleString()} candidates.
      {headline.seats_total.toLocaleString()} seats.
    </p>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Headline projection</p>
      <h2>{topParty ? `${shortPartyLabel(topParty.party)} ahead with ${topParty.seats.toLocaleString()} seats` : "Projection"}</h2>
    </div>
    <div class="party-bars party-bars-large">
      {headline.seat_tallies.map((t) => (
        <div class="bar-row">
          <span class="bar-label">{shortPartyLabel(t.party)}</span>
          <div class="bar-track">
            <div class="bar-fill" style={`width:${(t.share * 100).toFixed(1)}%; background:${partyColour(t.party)}`}></div>
          </div>
          <span class="bar-value">{t.seats.toLocaleString()} <span class="bar-share">({(t.share * 100).toFixed(1)}%)</span></span>
        </div>
      ))}
    </div>
    <p class="caption">
      Seats are awarded by ranking each ward's predicted party shares: the top N parties win the N seats up in that ward.
      <a href="/methodology/">How the model works →</a>
    </p>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">How accurate</p>
      <h2>Tested against the actual May 2024 results</h2>
    </div>
    <p>
      We replayed the same model against the real May 2024 contests across {headline.ward_count.toLocaleString()} wards.
      The model called the winner correctly in <strong>{(headline.backtest_winner_accuracy * 100).toFixed(1)}%</strong> of contests
      with an average gap of <strong>{(headline.backtest_major_party_mae * 100).toFixed(2)}pp</strong> between predicted and actual party share.
    </p>
    <p>
      <a href="/data-quality/2024-backtest/">Full accuracy record →</a>
    </p>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">English councils</p>
      <h2>{localCouncils.length} councils on cycle</h2>
    </div>
    <table class="council-table">
      <thead><tr><th>Council</th><th>Wards</th><th>Seats up</th><th>Top forecast</th></tr></thead>
      <tbody>
        {localCouncils.map((c: any) => {
          const top = Object.entries(c.predicted_seat_winners).sort((a, b) => (b[1] as number) - (a[1] as number))[0];
          return (
            <tr>
              <td><a href={`/seats/${c.council_slug}/`}>{c.council_name}</a></td>
              <td class="num">{c.ward_count}</td>
              <td class="num">{c.seats_up}</td>
              <td>{top ? <><span class="party-swatch" style={`background:${partyColour(top[0])}`}></span>{shortPartyLabel(top[0] as string)} <span class="muted">({top[1] as number})</span></> : "—"}</td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </section>

  {mayorCouncils.length > 0 && (
    <section class="section">
      <div class="section-head">
        <p class="eyebrow">Mayoralties</p>
        <h2>{mayorCouncils.length} directly elected mayors</h2>
      </div>
      <table class="council-table">
        <thead><tr><th>Mayoralty</th><th>Top forecast</th></tr></thead>
        <tbody>
          {mayorCouncils.map((c: any) => {
            const top = Object.entries(c.predicted_seat_winners).sort((a, b) => (b[1] as number) - (a[1] as number))[0];
            return (
              <tr>
                <td><a href={`/seats/${c.council_slug}/`}>{c.council_name}</a></td>
                <td>{top ? <><span class="party-swatch" style={`background:${partyColour(top[0])}`}></span>{shortPartyLabel(top[0] as string)}</> : "—"}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
      <p class="caption">
        Mayoral races are small-N and high-variance — treat the favourite shading with caution.
      </p>
    </section>
  )}

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Devolved parliaments</p>
      <h2>Senedd Cymru and the Scottish Parliament</h2>
    </div>
    <div class="feature-list">
      <article>
        <h3>Senedd 2026</h3>
        <p>The first election under the new closed-list PR system: 16 super-constituencies × 6 list seats each = 96 seats.</p>
        <p><a href="/forecasts/senedd-2026/">See Senedd forecast →</a></p>
      </article>
      <article>
        <h3>Scottish Parliament 2026</h3>
        <p>73 constituency seats (FPTP) + 56 regional list seats (d'Hondt) = 129 seats.</p>
        <p><a href="/forecasts/holyrood-2026/">See Holyrood forecast →</a></p>
      </article>
    </div>
  </section>
</BaseLayout>
