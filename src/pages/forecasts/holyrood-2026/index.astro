---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { loadHolyrood, partyColour } from "../../../lib/predictions";

const h = loadHolyrood();
const totals = h.scottish_seat_total_projection;
const ranked = Object.entries(totals).sort((a, b) => (b[1] as any).total_central - (a[1] as any).total_central);
---

<BaseLayout
  title="Scottish Parliament 2026 forecast"
  description="First public estimate of the May 2026 Scottish Parliament election. 73 constituency seats (FPTP) + 56 regional list seats (d'Hondt) = 129 seats."
>
  <section class="page-hero">
    <p class="eyebrow">Scottish Parliament 2026</p>
    <h1>129 seats — Additional Member System</h1>
    <p class="lede">
      73 FPTP constituency seats + 56 d'Hondt regional list seats across 8 regions.
    </p>
  </section>

  <section class="section prose-block">
    <h2>Important caveat</h2>
    <p>
      2026 brought boundary changes to the regional structure (a new "Central Scotland and Lothians West" + "Edinburgh and Lothians East" pair). The forecast applies current Scotland-wide polling uniformly per constituency,
      with constituency-level 2021 baselines where available, and runs d'Hondt per region with prior-seats
      apportioned as the Scotland-wide constituency wins divided across the 8 regions. Region-specific baselines
      and exact constituency-to-region mapping under the new boundaries are a planned upgrade.
    </p>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Total seat projection (129 seats)</p>
      <h2>Scotland-wide</h2>
    </div>
    <table class="seat-table">
      <thead><tr><th>Party</th><th>Constituency (FPTP)</th><th>List (d'Hondt)</th><th>Total (central)</th></tr></thead>
      <tbody>
        {ranked.map(([party, t]: [string, any]) => (
          <tr>
            <td><span class="party-swatch" style={`background:${partyColour(party)}`}></span>{party}</td>
            <td>{t.constituency}</td>
            <td>{t.list_central}</td>
            <td><strong>{t.total_central}</strong></td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Constituencies</p>
      <h2>73 FPTP predictions</h2>
    </div>
    <table class="constituency-table">
      <thead><tr><th>Constituency</th><th>Predicted winner</th><th>Top share</th></tr></thead>
      <tbody>
        {h.constituency_predictions.map((c: any) => (
          <tr>
            <td>{c.constituency}</td>
            <td><span class="party-swatch" style={`background:${partyColour(c.predicted_winner)}`}></span>{c.predicted_winner}</td>
            <td style="color: var(--muted)">{(c.predicted_winner_share * 100).toFixed(1)}%</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Regions</p>
      <h2>8 regions × 7 list seats</h2>
    </div>
    {h.region_predictions.map((r: any) => {
      const central = Object.entries(r.central).filter(([_, n]) => (n as number) > 0).sort((a, b) => (b[1] as number) - (a[1] as number));
      return (
        <div class="region-card">
          <h3>{r.region}</h3>
          <p style="font-size: 0.875rem; color: var(--muted)">7 list seats — central allocation:</p>
          <div>
            {central.length === 0 && <span style="color: var(--muted)">All 7 list seats projected to constituency winners (no list compensation needed)</span>}
            {central.map(([party, seats]) => (
              <span style="margin-right: 0.75rem">
                <span class="party-swatch" style={`background:${partyColour(party)}`}></span>{party} {seats as number}
              </span>
            ))}
          </div>
        </div>
      );
    })}
  </section>

  <section class="section prose-block">
    <h2>Inputs</h2>
    <p><strong>2021 Holyrood constituency baseline:</strong> SNP 47.9%, Lab 21.8%, Con 21.8%, LD 6.6%, Green 1.3%.</p>
    <p><strong>2021 Holyrood regional list baseline:</strong> SNP 40.2%, Con 23.4%, Lab 17.9%, Green 8.2%, LD 5.4%, Reform 0%.</p>
    <p><strong>Scottish polling:</strong> Auto-refreshed daily as the Wikipedia rolling 14-day average of every Scottish poll.</p>
    <p><strong>Method:</strong> per-constituency 2021 result + Scotland-wide swing → FPTP winner. Per-region 2021 list shares + Scotland-wide swing → d'Hondt over 7 list seats with priorSeats apportioned as Scotland-wide constituency wins / 8 regions.</p>
  </section>
</BaseLayout>

<style>
.seat-table, .constituency-table { width: 100%; border-collapse: collapse; margin-top: 0.5rem; }
.seat-table th, .seat-table td, .constituency-table th, .constituency-table td { padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--border); text-align: left; }
.seat-table th, .constituency-table th { font-weight: 600; color: var(--muted); font-size: 0.875rem; }
.region-card { background: var(--surface); padding: 1rem; border-radius: 8px; border: 1px solid var(--border); margin-bottom: 0.75rem; }
.region-card h3 { margin: 0 0 0.5rem 0; }
.party-swatch { display: inline-block; width: 0.75rem; height: 0.75rem; border-radius: 2px; margin-right: 0.5rem; vertical-align: middle; }
</style>
