---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Terms" description="Terms of use and forecast disclaimer for UK Elections.">
  <section class="page-hero">
    <p class="eyebrow">Terms</p>
    <h1>Use the data with the caveats attached.</h1>
  </section>
  <section class="section prose-block">
    <p>UK Elections is an independent research and publishing project. It is not an official election authority and does not provide electoral registration, voting, or legal advice.</p>
    <p>Forecasts are probabilistic estimates, not guarantees. Candidate, result, and boundary records should be checked against the linked source before operational use.</p>
  </section>
</BaseLayout>
