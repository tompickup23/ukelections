---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import {
  loadIdentity,
  loadPredictions,
  loadHistory,
  loadLaProj,
  loadLaImd,
  rankedShares,
  formatPct,
  partyColour,
} from "../../../../lib/predictions";

export async function getStaticPaths() {
  const identity = loadIdentity();
  const wards = identity.wards.filter((w) => w.tier === "local" || w.tier === "mayor");
  return wards.map((w) => ({
    params: { council: w.council_slug, ward: w.ward_slug || w.gss_code || w.ballot_paper_id.split(".").slice(2, -1).join(".") },
    props: { ward: w },
  }));
}

const { ward } = Astro.props;
const predictions = loadPredictions().predictions;
const history = loadHistory();
const laProj = loadLaProj();
const laImd = loadLaImd();
const wp = predictions[ward.ballot_paper_id];

const wardKey = `${ward.tier}::${ward.council_slug}::${ward.ward_slug}`;
const historicBallots = (history.by_ward_slug || {})[wardKey] || [];
const historicResults = historicBallots
  .map((id: string) => history.by_ballot[id])
  .filter(Boolean)
  .sort((a: any, b: any) => b.election_date.localeCompare(a.election_date))
  .slice(0, 5);

const lad24 = wp?.lad24cd || null;
const ladProj = lad24 ? laProj.projections[lad24] : null;
const ladImd = lad24 ? laImd.imd[lad24] : null;

const ranked = rankedShares(wp?.prediction || null);
const top = ranked[0];

const tierLabel = { local: "Local council", mayor: "Mayoralty" }[ward.tier] || ward.tier;
const title = `${ward.ward_name}${ward.council_name ? ` — ${ward.council_name}` : ""}`;
const description = wp?.prediction
  ? `Forecast for ${ward.ward_name} on 2026-05-07. Top: ${top[0]} ${formatPct(top[1].pct)}.`
  : `${ward.ward_name} (${ward.council_name}) on 2026-05-07. ${wp?.cancelled ? "Election cancelled." : "No prediction available — see methodology."}`;

const confidenceLabel = { high: "High", medium: "Medium", low: "Low", none: "Not available" }[wp?.confidence || "none"];
---

<BaseLayout title={title} description={description}>
  <section class="page-hero">
    <p class="eyebrow">{tierLabel}</p>
    <h1>{ward.ward_name}</h1>
    <p class="lede">
      {ward.council_name} · GSS <code>{ward.gss_code || "—"}</code> · {ward.winner_count} {ward.winner_count === 1 ? "seat" : "seats"} contested on 2026-05-07
    </p>
    <p style="color: var(--muted)">
      {ward.candidate_count} candidates from {ward.parties_standing.length} {ward.parties_standing.length === 1 ? "party" : "parties"} · Confidence: <strong>{confidenceLabel}</strong>
      {ward.sopn_url && (<>{" · "}<a href={ward.sopn_url}>Statement of Persons Nominated</a></>)}
    </p>
  </section>

  {wp?.cancelled && (
    <section class="section prose-block">
      <h2>Election cancelled</h2>
      <p>This ward's election on 2026-05-07 has been cancelled, most likely due to a candidate-death postponement. A by-election will be held on a later date.</p>
    </section>
  )}

  {wp?.prediction && (
    <section class="section">
      <div class="section-head">
        <p class="eyebrow">Predicted vote share</p>
        <h2>What the model expects</h2>
      </div>
      <table class="prediction-table">
        <thead>
          <tr><th>Party</th><th>Predicted share</th><th>≈ votes</th></tr>
        </thead>
        <tbody>
          {ranked.map(([party, p]) => (
            <tr>
              <td>
                <span class="party-swatch" style={`background:${partyColour(party)}`}></span>
                {party}
              </td>
              <td><strong>{formatPct(p.pct)}</strong></td>
              <td style="color: var(--muted)">{p.votes ?? "—"}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p style="font-size: 0.875rem; color: var(--muted); margin-top: 0.75rem">
        Predictions are point estimates derived from the latest baseline contest plus a national-swing adjustment dampened by 0.65 for local elections, then a UKD demographic adjustment at LA level. See the methodology section below.
      </p>
    </section>
  )}

  {!wp?.prediction && !wp?.cancelled && (
    <section class="section prose-block">
      <h2>No prediction available</h2>
      <p>{wp?.methodology?.[0]?.description || "No prior contest results available for this ward in our Democracy Club history bundle. This typically means the ward has been redrawn since 2016."}</p>
    </section>
  )}

  {historicResults.length > 0 && (
    <section class="section">
      <div class="section-head">
        <p class="eyebrow">Recent contests</p>
        <h2>What happened last time</h2>
      </div>
      <table class="history-table">
        <thead>
          <tr><th>Date</th><th>Type</th><th>Winner</th><th>Top share</th><th>Source</th></tr>
        </thead>
        <tbody>
          {historicResults.map((r: any) => {
            const total = (r.candidates || []).reduce((s: number, c: any) => s + (c.votes || 0), 0);
            const top = [...(r.candidates || [])].sort((a, b) => (b.votes || 0) - (a.votes || 0))[0];
            const share = top && total > 0 ? top.votes / total : null;
            return (
              <tr>
                <td>{r.election_date}</td>
                <td style="color: var(--muted)">{r.is_by_election ? "By-election" : "Cycle"}</td>
                <td>{top?.party_name || "—"}</td>
                <td>{share != null ? formatPct(share) : "—"}</td>
                <td>{r.source ? <a href={r.source}>declaration</a> : "—"}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </section>
  )}

  {ward.parties_standing.length > 0 && (
    <section class="section">
      <div class="section-head">
        <p class="eyebrow">Candidates 2026</p>
        <h2>Parties on the ballot</h2>
      </div>
      <ul class="party-list">
        {ward.parties_standing.map((p: string) => (
          <li>
            <span class="party-swatch" style={`background:${partyColour(p)}`}></span>
            {p}
          </li>
        ))}
      </ul>
      {ward.sopn_url && (
        <p style="margin-top: 0.75rem"><a href={ward.sopn_url}>View official Statement of Persons Nominated (PDF)</a></p>
      )}
    </section>
  )}

  {(ladProj || ladImd) && (
    <section class="section prose-block">
      <h2>How this ward looks demographically</h2>
      <p>
        These figures come from {ladProj?.area_name || ward.council_name} as a whole. We apply the same LA-level adjustment to every ward in the same local authority — Stage 1 of UK Elections does not yet break demographics down to ward level outside the AI DOGE pilot footprint.
      </p>
      <ul>
        {ladProj && (
          <>
            <li>White British (projected May 2026): <strong>{(ladProj.white_british_pct_projected * 100).toFixed(1)}%</strong> (Census 2021: {(ladProj.groups_2021?.white_british ?? 0).toFixed(1)}%)</li>
            <li>Asian heritage (projected May 2026): <strong>{(ladProj.asian_pct_projected * 100).toFixed(1)}%</strong> (Census 2021: {(ladProj.groups_2021?.asian ?? 0).toFixed(1)}%)</li>
          </>
        )}
        {ladImd && (
          <li>Average IMD 2019 decile: <strong>{ladImd.avg_imd_decile.toFixed(1)}</strong> (1 = most deprived, 10 = least)</li>
        )}
      </ul>
    </section>
  )}

  {wp?.methodology && wp.methodology.length > 0 && (
    <section class="section prose-block">
      <h2>How this prediction was made</h2>
      <ol>
        {wp.methodology.map((step: any) => (
          <li>
            <strong>{step.name}</strong>
            {step.description && <> — {step.description}</>}
          </li>
        ))}
      </ol>
      <p style="font-size: 0.875rem; color: var(--muted)">
        Model version: <code>{wp.model_version}</code> · Baseline date: <code>{wp.baseline_date || "n/a"}</code>
      </p>
    </section>
  )}

  <section class="section">
    <p><a href={`/seats/${ward.council_slug}/`}>← Back to {ward.council_name}</a></p>
  </section>
</BaseLayout>

<style>
.prediction-table, .history-table { width: 100%; border-collapse: collapse; margin-top: 0.5rem; }
.prediction-table th, .prediction-table td, .history-table th, .history-table td { padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--border); text-align: left; }
.prediction-table th, .history-table th { font-weight: 600; color: var(--muted); font-size: 0.875rem; }
.party-swatch { display: inline-block; width: 0.75rem; height: 0.75rem; border-radius: 2px; margin-right: 0.5rem; vertical-align: middle; }
.party-list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.5rem; }
.party-list li { background: var(--surface); padding: 0.5rem 0.75rem; border-radius: 6px; border: 1px solid var(--border); }
</style>
