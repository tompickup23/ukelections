---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import {
  loadIdentity,
  loadPredictions,
  loadHistory,
  loadLaProj,
  loadLaImd,
  loadMay7BacktestForWard,
  rankedShares,
  formatPct,
  partyColour,
} from "../../../../lib/predictions";
import { shortPartyLabel } from "../../../../lib/siteData";

export async function getStaticPaths() {
  const identity = loadIdentity();
  const wards = identity.wards.filter((w) => w.tier === "local" || w.tier === "mayor");
  return wards.map((w) => ({
    params: { council: w.council_slug, ward: w.ward_slug || w.gss_code || w.ballot_paper_id.split(".").slice(2, -1).join(".") },
    props: { ward: w },
  }));
}

const { ward } = Astro.props;
const predictions = loadPredictions().predictions;
const history = loadHistory();
const laProj = loadLaProj();
const laImd = loadLaImd();
const wp = predictions[ward.ballot_paper_id];

const wardKey = `${ward.tier}::${ward.council_slug}::${ward.ward_slug}`;
const historicBallots = (history.by_ward_slug || {})[wardKey] || [];
const historicResults = historicBallots
  .map((id: string) => history.by_ballot[id])
  .filter(Boolean)
  .sort((a: any, b: any) => b.election_date.localeCompare(a.election_date))
  .slice(0, 5);

const lad24 = wp?.lad24cd || null;
const ladProj = lad24 ? laProj.projections[lad24] : null;
const ladImd = lad24 ? laImd.imd[lad24] : null;

const ranked = rankedShares(wp?.prediction || null);
const top = ranked[0];

const tierLabel = { local: "Local council", mayor: "Mayoralty" }[ward.tier] || ward.tier;
const title = `${ward.ward_name}${ward.council_name ? ` — ${ward.council_name}` : ""}`;
const description = wp?.prediction
  ? `Forecast for ${ward.ward_name} on Thursday 7 May 2026. Top: ${shortPartyLabel(top[0])} ${formatPct(top[1].pct)}.`
  : `${ward.ward_name} (${ward.council_name}) on Thursday 7 May 2026. ${wp?.cancelled ? "Election cancelled." : "No prediction available."}`;

const confidenceLabel = { high: "High", medium: "Medium", low: "Low", none: "Not available" }[wp?.confidence || "none"];

// Per-ward 7 May 2026 backtest: did we call the winner correctly here?
// Row keys are stable Democracy Club ballot IDs (local.<council>.<ward>.<date>).
const wardBacktest = ward.ballot_paper_id ? loadMay7BacktestForWard(ward.ballot_paper_id) : null;
const btParties: Array<{ party: string; pred: number; actual: number; delta: number }> = wardBacktest
  ? [
      { party: "Reform UK", pred: wardBacktest.reform_pred || 0, actual: wardBacktest.reform_actual || 0, delta: wardBacktest.reform_delta || 0 },
      { party: "Labour", pred: wardBacktest.lab_pred || 0, actual: wardBacktest.lab_actual || 0, delta: wardBacktest.lab_delta || 0 },
      { party: "Conservative", pred: wardBacktest.con_pred || 0, actual: wardBacktest.con_actual || 0, delta: wardBacktest.con_delta || 0 },
    ].filter((r) => r.pred > 0 || r.actual > 0)
  : [];
---

<BaseLayout title={title} description={description}>
  <section class="page-hero">
    <p class="eyebrow">{tierLabel} · {ward.council_name}</p>
    <h1>{ward.ward_name}</h1>
    <p class="lede">
      {ward.winner_count} {ward.winner_count === 1 ? "seat" : "seats"} contested on Thursday 7 May 2026.
      {ward.candidate_count} candidates from {ward.parties_standing.length} {ward.parties_standing.length === 1 ? "party" : "parties"}.
    </p>
    <p class="meta-row">
      Confidence in the forecast: <strong>{confidenceLabel}</strong>
      {ward.sopn_url && (<>{" · "}<a href={ward.sopn_url}>Official Statement of Persons Nominated (PDF)</a></>)}
    </p>
  </section>

  {wp?.cancelled && (
    <section class="section prose-block">
      <h2>This election has been cancelled</h2>
      <p>The 7 May 2026 election in this ward has been cancelled, most likely because of a candidate-death postponement. A by-election will be held on a later date.</p>
    </section>
  )}

  {wp?.prediction && (
    <section class="section">
      <div class="section-head">
        <p class="eyebrow">Predicted vote share</p>
        <h2>What the model expects</h2>
      </div>
      <div class="party-bars party-bars-large">
        {ranked.map(([party, p]) => (
          <div class="bar-row">
            <span class="bar-label">{shortPartyLabel(party)}</span>
            <div class="bar-track">
              <div class="bar-fill" style={`width:${(p.pct * 100).toFixed(1)}%; background:${partyColour(party)}`}></div>
            </div>
            <span class="bar-value">{formatPct(p.pct)}</span>
          </div>
        ))}
      </div>
      <p class="caption">
        Predictions are point estimates: the model's best guess, not a guarantee. The "How this prediction was made"
        section below lists every step that shaped this forecast.
      </p>
    </section>
  )}

  {!wp?.prediction && !wp?.cancelled && (
    <section class="section prose-block">
      <h2>No prediction available</h2>
      <p>{wp?.methodology?.[0]?.description || "We don't yet have enough prior contest results in this ward to produce a forecast — typically because the ward has been redrawn since 2016."}</p>
    </section>
  )}

  {wardBacktest && (
    <section class="section">
      <div class="section-head">
        <p class="eyebrow">How accurate was the model here?</p>
        <h2>Our 7 May 2026 forecast for {ward.ward_name}</h2>
      </div>
      <div class="backtest-callout">
        <strong>
          {wardBacktest.winner_match ? "✓ Winner called correctly" : "✗ Winner missed"}
        </strong>
        — predicted <span class="party-pill" style={`background:${partyColour(wardBacktest.predicted_winner)}`}></span> {shortPartyLabel(wardBacktest.predicted_winner)},
        actual <span class="party-pill" style={`background:${partyColour(wardBacktest.actual_winner)}`}></span> {shortPartyLabel(wardBacktest.actual_winner)}.
        <span class="backtest-detail">
          Major-party MAE: <strong>{((wardBacktest.major_party_mae || 0) * 100).toFixed(2)}pp</strong>
          across the parties below.
        </span>
      </div>
      {btParties.length > 0 && (
        <table class="seat-table">
          <thead><tr><th>Party</th><th class="num">Predicted</th><th class="num">Actual</th><th class="num">Gap</th></tr></thead>
          <tbody>
            {btParties.map((r) => (
              <tr>
                <td><span class="party-pill" style={`background:${partyColour(r.party)}`}></span> {shortPartyLabel(r.party)}</td>
                <td class="num">{(r.pred * 100).toFixed(1)}%</td>
                <td class="num">{(r.actual * 100).toFixed(1)}%</td>
                <td class="num">
                  <span class={r.delta > 0 ? "swing-up" : (r.delta < 0 ? "swing-down" : "swing-flat")}>
                    {r.delta > 0 ? "+" : ""}{(r.delta * 100).toFixed(1)}pp
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
      <p class="caption">
        Positive gap = we predicted that party would win more share than they did. See the {" "}
        <a href={`/seats/${ward.council_slug}/`}>full {ward.council_name} accuracy summary</a> or{" "}
        <a href="/past-results/">the national audit</a>.
      </p>
    </section>
  )}

  {historicResults.length > 0 && (
    <section class="section">
      <div class="section-head">
        <p class="eyebrow">Recent contests</p>
        <h2>What happened last time</h2>
      </div>
      <table class="seat-table">
        <thead>
          <tr><th>Date</th><th>Type</th><th>Winner</th><th>Top share</th><th>Source</th></tr>
        </thead>
        <tbody>
          {historicResults.map((r: any) => {
            const total = (r.candidates || []).reduce((s: number, c: any) => s + (c.votes || 0), 0);
            const top = [...(r.candidates || [])].sort((a, b) => (b.votes || 0) - (a.votes || 0))[0];
            const share = top && total > 0 ? top.votes / total : null;
            return (
              <tr>
                <td>{r.election_date}</td>
                <td class="muted">{r.is_by_election ? "By-election" : "Cycle"}</td>
                <td>{shortPartyLabel(top?.party_name) || "—"}</td>
                <td class="num">{share != null ? formatPct(share) : "—"}</td>
                <td>{r.source ? <a href={r.source}>declaration</a> : "—"}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </section>
  )}

  {ward.parties_standing.length > 0 && (
    <section class="section">
      <div class="section-head">
        <p class="eyebrow">Candidates 2026</p>
        <h2>Parties on the ballot</h2>
      </div>
      <ul class="party-list">
        {ward.parties_standing.map((p: string) => (
          <li>
            <span class="party-swatch" style={`background:${partyColour(p)}`}></span>
            {shortPartyLabel(p)}
          </li>
        ))}
      </ul>
      {ward.sopn_url && (
        <p class="caption"><a href={ward.sopn_url}>View the official Statement of Persons Nominated (PDF)</a></p>
      )}
    </section>
  )}

  {(ladProj || ladImd) && (
    <section class="section prose-block">
      <h2>How this area looks demographically</h2>
      <p>
        Figures are for {ladProj?.area_name || ward.council_name} as a whole. The same local-authority figures are used
        for every ward in the council — finer ward-level demographics will land in a future release.
      </p>
      <ul>
        {ladProj && (
          <>
            <li>White British (projected May 2026): <strong>{(ladProj.white_british_pct_projected * 100).toFixed(1)}%</strong> (Census 2021: {(ladProj.groups_2021?.white_british ?? 0).toFixed(1)}%)</li>
            <li>Asian heritage (projected May 2026): <strong>{(ladProj.asian_pct_projected * 100).toFixed(1)}%</strong> (Census 2021: {(ladProj.groups_2021?.asian ?? 0).toFixed(1)}%)</li>
          </>
        )}
        {ladImd && (
          <li>Average area deprivation decile: <strong>{ladImd.avg_imd_decile.toFixed(1)}</strong> (1 = most deprived, 10 = least)</li>
        )}
      </ul>
    </section>
  )}

  {wp?.methodology && wp.methodology.length > 0 && (
    <details class="section method-details">
      <summary>How this prediction was made</summary>
      <ol class="numbered-list">
        {wp.methodology.map((step: any) => (
          <li>
            <strong>{step.name}</strong>
            {step.description && <> — {step.description}</>}
          </li>
        ))}
      </ol>
      <p class="muted-row">
        <a href="/methodology/national-model/">Read the full local-elections methodology →</a>
      </p>
    </details>
  )}

  <section class="section">
    <p><a href={`/seats/${ward.council_slug}/`}>← Back to {ward.council_name}</a></p>
  </section>
</BaseLayout>

<style>
.party-list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.5rem; }
.party-list li { background: var(--surface); padding: 0.5rem 0.75rem; border-radius: 6px; border: 1px solid var(--border); }
</style>
