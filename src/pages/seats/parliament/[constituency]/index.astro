---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { loadGePredictions, partyColour } from "../../../../lib/predictions";
import { shortPartyLabel } from "../../../../lib/siteData";

export async function getStaticPaths() {
  const ge = loadGePredictions();
  const out = [] as any[];
  for (const [slug, p] of Object.entries(ge.predictions || {})) {
    if (!(p as any)?.prediction) continue;
    out.push({ params: { constituency: slug }, props: { record: p } });
  }
  return out;
}

const { record } = Astro.props as { record: any };
const ranked = Object.entries(record.prediction || {})
  .sort((a: any, b: any) => (b[1].pct || 0) - (a[1].pct || 0));
const ge2024Ranked = (record.ge2024?.candidates || [])
  .sort((a: any, b: any) => (b.pct || 0) - (a.pct || 0));

const mp = record.mp;
const slug = record.slug;
// Off-site cross-links — only public, party-neutral references.
const sisterLinks = [
  mp?.party === "Labour" || mp?.party === "Labour and Co-operative Party"
    ? { label: "Labour Tracker MP page", href: `https://labourtracker.co.uk/your-mp/${slug}/` }
    : null,
  { label: "TheyWorkForYou", href: `https://www.theyworkforyou.com/mp/?p=${encodeURIComponent(slug.replace(/-/g, " "))}` },
].filter(Boolean) as Array<{ label: string; href: string }>;

const winnerShare = ((record.prediction[record.winner]?.pct || 0) * 100).toFixed(1);
const margin = ((record.majority_pct || 0) * 100).toFixed(1);
const countryLabel = record.country?.replace(/_/g, " ");
const regionLabel = record.region?.replace(/_/g, " ");
---

<BaseLayout
  title={`${record.name} — General election forecast`}
  description={`If a UK general election were held this week, the model predicts ${shortPartyLabel(record.winner)} to win ${record.name} with a ${margin}pp margin over ${shortPartyLabel(record.runner_up)}.`}
>
  <section class="page-hero">
    <p class="eyebrow">General election forecast</p>
    <h1>{record.name}</h1>
    <p class="lede">
      Predicted winner: <strong><span class="party-pill" style={`background:${partyColour(record.winner)}`}></span> {shortPartyLabel(record.winner)}</strong>
      with <strong>{winnerShare}%</strong> of the vote, a {margin}pp margin over {shortPartyLabel(record.runner_up)}.
    </p>
    <p class="meta-row">
      {countryLabel}{regionLabel ? ` · ${regionLabel}` : ""}
    </p>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Predicted vote share</p>
      <h2>How the model expects this constituency to vote</h2>
    </div>
    <div class="party-bars party-bars-large">
      {ranked.map(([party, payload]: any) => {
        const pct = (payload.pct || 0);
        const ge24 = ge2024Ranked.find((c: any) => c.party_name === party || c.party === party);
        const swing = pct - (ge24?.pct || 0);
        return (
          <div class="bar-row">
            <span class="bar-label">{shortPartyLabel(party)}</span>
            <div class="bar-track">
              <div class="bar-fill" style={`width:${(pct * 100).toFixed(1)}%; background:${partyColour(party)}`}></div>
            </div>
            <span class="bar-value">{(pct * 100).toFixed(1)}% <span class={swing > 0 ? "swing-up" : (swing < 0 ? "swing-down" : "swing-flat")}>{swing > 0 ? "+" : ""}{(swing * 100).toFixed(1)}pp</span></span>
          </div>
        );
      })}
    </div>
    <p class="caption">Coloured number is the swing from the 2024 general election result.</p>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Sitting MP</p>
      <h2>{mp?.name || "No MP record on file"}</h2>
    </div>
    {mp ? (
      <ul class="plain-list">
        <li><strong>Party:</strong> {shortPartyLabel(mp.party)}</li>
        <li><strong>Tenure:</strong> {mp.tenure_years?.toFixed(1)} years (since {mp.since})</li>
        <li><strong>Status:</strong> {mp.status?.replace(/_/g, " ")}</li>
      </ul>
    ) : (
      <p>The constituency was created for the 2024 boundary review or the sitting MP record isn't yet ingested.</p>
    )}
    {sisterLinks.length > 0 && (
      <p class="muted-row">
        See also: {sisterLinks.map((l, i) => (
          <span>{i > 0 && " · "}<a href={l.href}>{l.label}</a></span>
        ))}
      </p>
    )}
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">2024 general election result</p>
      <h2>What happened on 4 July 2024</h2>
    </div>
    <table class="seat-table">
      <thead><tr><th>Candidate</th><th>Party</th><th class="num">Votes</th><th class="num">Share</th></tr></thead>
      <tbody>
        {ge2024Ranked.slice(0, 8).map((c: any) => (
          <tr>
            <td>{c.name || "—"}</td>
            <td><span class="party-pill" style={`background:${partyColour(c.party_name)}`}></span> {shortPartyLabel(c.party_name)}</td>
            <td class="num">{(c.votes || 0).toLocaleString()}</td>
            <td class="num">{((c.pct || 0) * 100).toFixed(1)}%</td>
          </tr>
        ))}
      </tbody>
    </table>
    {record.ge2024?.source_url && (
      <p class="caption">Source: <a href={record.ge2024.source_url}>Returning officer declaration</a></p>
    )}
  </section>

  <details class="section method-details">
    <summary>How this forecast was built</summary>
    <ol class="numbered-list">
      {record.methodology?.map((m: any) => (
        <li><strong>{m.name}</strong>{m.description ? <> — {m.description}</> : null}</li>
      ))}
    </ol>
    <p class="muted-row">
      <a href="/methodology/general-election/">Read the full general election methodology →</a>
    </p>
  </details>
</BaseLayout>
