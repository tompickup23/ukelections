---
import BaseLayout from "../layouts/BaseLayout.astro";
import { partyColour } from "../lib/predictions";
import { loadMayHeadline, loadGeHeadline, countdownToMay, shortPartyLabel } from "../lib/siteData";

const may = loadMayHeadline();
const ge = loadGeHeadline();
const cd = countdownToMay();
const topMay = may.seat_tallies.slice(0, 4);
const topGe = ge.seat_tallies.slice(0, 4);
---

<BaseLayout
  title="UK Elections — what you'll be voting on, who's likely to win, and how confident we are"
  description={`Forecasts for May 7 2026 (every English council, the Senedd, and Holyrood) and the next UK general election. ${cd.has_passed ? "Result tracking" : `${cd.days_until} days to go`}.`}
>
  <section class="hero hero-v2">
    <p class="eyebrow">{cd.has_passed ? "Live results tracking" : `${cd.days_until} days to go · ${cd.date_pretty}`}</p>
    <h1>Who's going to win — and how sure are we?</h1>
    <p class="lede">
      Plain-English forecasts for every UK election: this May's local councils, the Senedd, the Scottish Parliament,
      and a constantly-updated forecast of the next UK general election.
    </p>
    <div class="action-row" aria-label="Primary actions">
      <a class="button primary" href="/your-area/">Find my ward</a>
      <a class="button" href="/forecasts/may-2026/">May 7 election</a>
      <a class="button" href="/forecasts/general-election/">General election</a>
    </div>
  </section>

  <section class="headline-grid" aria-label="Headline projections">
    <article class="headline-card">
      <header>
        <span class="kicker">May 7 — English councils, Senedd, Holyrood</span>
        <h2>{may.seats_total.toLocaleString()} seats up for election</h2>
      </header>
      <p class="card-lede">
        {may.council_count} English councils plus mayoralties, the Senedd Cymru, and the Scottish Parliament.
        Forecasts ready for every contested seat.
      </p>
      <div class="party-bars">
        {topMay.map((t) => (
          <div class="bar-row">
            <span class="bar-label">{shortPartyLabel(t.party)}</span>
            <div class="bar-track">
              <div class="bar-fill" style={`width:${(t.share * 100).toFixed(1)}%; background:${partyColour(t.party)}`}></div>
            </div>
            <span class="bar-value">{t.seats.toLocaleString()}</span>
          </div>
        ))}
      </div>
      <a class="card-cta" href="/forecasts/may-2026/">See May 7 forecast →</a>
    </article>

    <article class="headline-card">
      <header>
        <span class="kicker">If a UK general election were held today</span>
        <h2>Reform UK projected to win {ge.seat_tallies[0]?.seats || 0} seats</h2>
      </header>
      <p class="card-lede">
        All 650 UK parliamentary constituencies, refreshed daily from current Westminster polling.
        This is what would happen if the country voted right now.
      </p>
      <div class="party-bars">
        {topGe.map((t) => (
          <div class="bar-row">
            <span class="bar-label">{shortPartyLabel(t.party)}</span>
            <div class="bar-track">
              <div class="bar-fill" style={`width:${(t.share * 100).toFixed(1)}%; background:${partyColour(t.party)}`}></div>
            </div>
            <span class="bar-value">{t.seats.toLocaleString()}</span>
          </div>
        ))}
      </div>
      <a class="card-cta" href="/forecasts/general-election/">See general election forecast →</a>
    </article>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">How accurate are these forecasts?</p>
      <h2>We test the model against past elections — and publish the results.</h2>
    </div>
    <div class="accuracy-grid">
      <article>
        <span class="big-number">{(may.backtest_winner_accuracy * 100).toFixed(0)}%</span>
        <p class="big-number-label">winners called correctly when we replayed the model on the May 2024 results</p>
      </article>
      <article>
        <span class="big-number">{(may.backtest_major_party_mae * 100).toFixed(1)}pp</span>
        <p class="big-number-label">average gap between predicted and actual party share, May 2024 backtest</p>
      </article>
      <article>
        <span class="big-number">{(ge.backtest_winner_accuracy * 100).toFixed(0)}%</span>
        <p class="big-number-label">winners called correctly when we replayed the model on the 2024 general election</p>
      </article>
    </div>
    <p class="muted-row">
      <a href="/data-quality/">See the full accuracy record →</a>
    </p>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">What you can do here</p>
      <h2>Built for voters, journalists, and campaigners alike.</h2>
    </div>
    <div class="feature-list">
      <article>
        <h3>Find your ward</h3>
        <p>Type a UK postcode, town, or council and we'll show your specific contest on May 7 — candidates, parties, the forecast and the backtest.</p>
        <p><a href="/your-area/">Find my ward →</a></p>
      </article>
      <article>
        <h3>Read the headline</h3>
        <p>Every election family has a single page with the seat-split projection, the parties on the ballot, and the local detail underneath.</p>
        <p><a href="/forecasts/may-2026/">May 7 →</a> · <a href="/forecasts/general-election/">General election →</a></p>
      </article>
      <article>
        <h3>Check our working</h3>
        <p>Every prediction lists the model steps that produced it. The full method, the backtest, the data sources and the open downloads live in <a href="/methodology/">About</a>.</p>
      </article>
    </div>
  </section>
</BaseLayout>
