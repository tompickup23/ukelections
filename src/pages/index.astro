---
import BaseLayout from "../layouts/BaseLayout.astro";
import { partyColour } from "../lib/predictions";
import {
  loadGeHeadline,
  loadMay7Headline,
  shortPartyLabel,
  partySlugToName,
} from "../lib/siteData";

const ge = loadGeHeadline();
const may7 = loadMay7Headline();
const topGe = ge.seat_tallies.slice(0, 4);

// Council-majority tally — the four parties that won the most council majorities on May 7.
const councilMajorities = Object.entries(may7.control_by_party)
  .filter(([, n]) => (n as number) > 0)
  .sort((a, b) => (b[1] as number) - (a[1] as number));
const totalMajorities = councilMajorities.reduce((s, [, n]) => s + (n as number), 0);
---

<BaseLayout
  title="UK Elections — every council, every constituency, every forecast"
  description={`The May 7 2026 result and accuracy audit, the rolling forecast for every one of the 650 UK constituencies, and the next council election date (or "TBC" where Local Government Reorganisation is in play).`}
>
  <section class="hero hero-v2">
    <p class="eyebrow">May 7 shipped · GE forecast live · next council dates listed</p>
    <h1>Every council, every constituency, every forecast.</h1>
    <p class="lede">
      The May 7 2026 result, our scored accuracy, the rolling forecast for all 650 UK general-election seats, and
      the next election date for each council — including a clear <strong>TBC</strong> where Local Government
      Reorganisation is in play, rather than a misleading date.
    </p>
    <div class="action-row" aria-label="Primary actions">
      <a class="button primary" href="/your-area/">Find my ward</a>
      <a class="button" href="/councils/">All councils</a>
      <a class="button" href="/forecasts/general-election/">General election forecast</a>
      <a class="button" href="/past-results/">May 7 results</a>
    </div>
  </section>

  <section class="headline-grid" aria-label="Headline projections">
    <article class="headline-card">
      <header>
        <span class="kicker">May 7 2026 — results in</span>
        <h2>{may7.reform_majorities} Reform UK majorities, {may7.reform_seats_won.toLocaleString()} seats</h2>
      </header>
      <p class="card-lede">
        {may7.contesting_councils} English and Welsh councils contested. {totalMajorities} councils now have a single-party
        majority; {may7.noc_count} are in no-overall-control. Our locked forecast called the winner correctly in{" "}
        <strong>{(may7.live_winner_accuracy * 100).toFixed(1)}%</strong> of evaluated wards.
      </p>
      <div class="party-bars">
        {councilMajorities.slice(0, 4).map(([slug, n]) => {
          const name = partySlugToName(slug);
          const share = totalMajorities > 0 ? (n as number) / totalMajorities : 0;
          return (
            <div class="bar-row">
              <span class="bar-label">{shortPartyLabel(name)}</span>
              <div class="bar-track">
                <div class="bar-fill" style={`width:${(share * 100).toFixed(1)}%; background:${partyColour(name)}`}></div>
              </div>
              <span class="bar-value">{(n as number).toLocaleString()}</span>
            </div>
          );
        })}
      </div>
      <p class="caption">Councils with a single-party majority</p>
      <a class="card-cta" href="/past-results/">See May 7 results and accuracy →</a>
    </article>

    <article class="headline-card">
      <header>
        <span class="kicker">If a UK general election were held today</span>
        <h2>Reform UK projected to win {ge.seat_tallies[0]?.seats || 0} seats</h2>
      </header>
      <p class="card-lede">
        All 650 UK parliamentary constituencies, refreshed daily from current Westminster polling.
        This is what would happen if the country voted right now.
      </p>
      <div class="party-bars">
        {topGe.map((t) => (
          <div class="bar-row">
            <span class="bar-label">{shortPartyLabel(t.party)}</span>
            <div class="bar-track">
              <div class="bar-fill" style={`width:${(t.share * 100).toFixed(1)}%; background:${partyColour(t.party)}`}></div>
            </div>
            <span class="bar-value">{t.seats.toLocaleString()}</span>
          </div>
        ))}
      </div>
      <p class="caption">Projected Westminster seats</p>
      <a class="card-cta" href="/forecasts/general-election/">See general election forecast →</a>
    </article>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">How accurate were we?</p>
      <h2>The May 7 forecast, scored against the actual count.</h2>
    </div>
    <div class="accuracy-grid">
      <article>
        <span class="big-number">{(may7.live_winner_accuracy * 100).toFixed(1)}%</span>
        <p class="big-number-label">winners called correctly on May 7 2026 (our locked, sha256-witnessed forecast)</p>
      </article>
      <article>
        <span class="big-number">{(may7.live_major_party_mae * 100).toFixed(2)}pp</span>
        <p class="big-number-label">average gap between our predicted vote share and the actual vote share, per party</p>
      </article>
      <article>
        <span class="big-number">{(ge.backtest_winner_accuracy * 100).toFixed(0)}%</span>
        <p class="big-number-label">winners called correctly when we replayed the GE model on the 2024 general election</p>
      </article>
    </div>
    <p class="muted-row">
      <a href="/past-results/">Full May 7 audit →</a>
      · <a href="/data-quality/">All backtests →</a>
    </p>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">What you can do here</p>
      <h2>Built for voters, journalists, and campaigners alike.</h2>
    </div>
    <div class="feature-list">
      <article>
        <h3>Find your ward or constituency</h3>
        <p>Type a UK postcode, town, or council and we'll show your specific contest — candidates, parties, the May 7 result where applicable, and the GE forecast.</p>
        <p><a href="/your-area/">Find my ward →</a></p>
      </article>
      <article>
        <h3>Browse every council</h3>
        <p>The full list of {may7.contesting_councils} councils with the May 7 result, who controls them now, and when they next vote. Two-tier councils awaiting Local Government Reorganisation are marked <strong>TBC</strong>.</p>
        <p><a href="/councils/">All councils →</a></p>
      </article>
      <article>
        <h3>Check our working</h3>
        <p>Every prediction lists the model steps that produced it. The full method, every backtest, the data sources and open downloads live in <a href="/methodology/">About</a>. May 7 was scored after the count — see <a href="/past-results/">our accuracy audit</a>.</p>
      </article>
    </div>
  </section>
</BaseLayout>
