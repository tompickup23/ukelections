---
import BaseLayout from "../layouts/BaseLayout.astro";
import { slugifyAreaName } from "../lib/site";
import schoolPressure from "../data/live/school-pressure.json";

const sp = schoolPressure as any;
const areasWithData = Object.entries(sp.areas)
  .filter(([_, d]: any) => d.dataAvailable)
  .map(([code, d]: any) => ({ code, ...d }))
  .sort((a, b) => (b.minorityPupilsPct ?? 0) - (a.minorityPupilsPct ?? 0));
---

<BaseLayout
  title="School demographic pressure"
  description={`School ethnic composition across ${areasWithData.length} local authorities. DfE School Census 2024/25 data with projected growth.`}
>
  <h1>School demographic pressure</h1>
  <p class="desc">DfE School Census 2024/25: pupil ethnic composition by local authority. {areasWithData.length} areas with school data. Sorted by minority pupil share (descending).</p>

  <div class="stats-grid">
    <div class="stat-card"><span class="stat-value" style="color:var(--accent)">{areasWithData.length}</span><span class="stat-label">Areas with school data</span></div>
    <div class="stat-card"><span class="stat-value" style="color:var(--coral)">{areasWithData.filter(a => (a.minorityPupilsPct ?? 0) > 50).length}</span><span class="stat-label">Minority-majority schools</span></div>
    <div class="stat-card"><span class="stat-value" style="color:var(--accent-3)">{areasWithData.filter(a => (a.ealDemandGrowthPp ?? 0) > 10).length}</span><span class="stat-label">Areas with 10pp+ EAL growth projected</span></div>
  </div>

  <div class="area-table">
    <div class="area-table-header"><span>Area</span><span>WBI pupils</span><span>Minority</span><span>EAL growth</span><span>Total pupils</span></div>
    {areasWithData.slice(0, 50).map((a) => (
      <a href={`/places/${slugifyAreaName(a.areaName)}/`} class="area-row">
        <span class="name">{a.areaName}</span>
        <span class="val">{a.wbiPupilsPct?.toFixed(1) ?? "-"}%</span>
        <span class="val accent">{a.minorityPupilsPct?.toFixed(1) ?? "-"}%</span>
        <span class="val warn">{a.ealDemandGrowthPp != null ? `+${a.ealDemandGrowthPp.toFixed(1)}pp` : "-"}</span>
        <span class="val muted">{a.totalPupils?.toLocaleString() ?? "-"}</span>
      </a>
    ))}
  </div>
  <a href="/places/" class="cta-link">Browse all areas &rarr;</a>
</BaseLayout>

<style>
  h1 { font-family: "Sora", sans-serif; font-size: 1.8rem; font-weight: 800; margin: 0 0 0.5rem; }
  .desc { color: var(--muted); font-size: 0.92rem; margin: 0 0 1.5rem; max-width: 700px; }
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0.75rem; margin-bottom: 2rem; }
  .stat-card { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 1.25rem; display: flex; flex-direction: column; gap: 0.2rem; }
  .stat-value { font-family: "Sora", sans-serif; font-size: 1.75rem; font-weight: 800; line-height: 1; }
  .stat-label { font-size: 0.85rem; color: var(--muted); }
  .area-table { max-width: 800px; }
  .area-table-header { display: grid; grid-template-columns: 1fr 80px 80px 90px 100px; padding: 0.5rem 0.75rem; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); border-bottom: 1px solid var(--border-strong); }
  .area-row { display: grid; grid-template-columns: 1fr 80px 80px 90px 100px; align-items: center; padding: 0.5rem 0.75rem; text-decoration: none; color: var(--ink); border-bottom: 1px solid var(--border); transition: background 120ms; }
  .area-row:hover { background: rgba(79, 70, 229, 0.06); }
  .name { font-weight: 600; font-size: 0.88rem; }
  .val { font-family: "Sora", sans-serif; font-size: 0.85rem; font-weight: 700; }
  .val.accent { color: var(--accent); }
  .val.warn { color: var(--accent-3); }
  .val.muted { color: var(--muted); font-weight: 400; }
  .cta-link { display: inline-block; margin-top: 1.25rem; font-size: 0.92rem; font-weight: 700; color: var(--accent); text-decoration: none; }
  @media (max-width: 640px) { .area-table-header, .area-row { grid-template-columns: 1fr 70px 70px; } .area-row .val:nth-child(n+4) { display: none; } .area-table-header span:nth-child(n+4) { display: none; } }
</style>
