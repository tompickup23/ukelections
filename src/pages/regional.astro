---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublicPlaceAreas, getPublicPlaceRegions, buildPublicPlaceRegionPath } from "../lib/site";

const areas = getPublicPlaceAreas();
const regions = getPublicPlaceRegions();

// Compute region-level demographic stats
const regionStats = regions.map((region) => {
  const regionAreas = areas.filter(a => a.regionName === region.regionName);
  const totalPop = regionAreas.reduce((s, a) => s + (a.population ?? 0), 0);
  const weightedWbi = totalPop > 0
    ? regionAreas.reduce((s, a) => s + (a.wbiPct2021 ?? 0) * (a.population ?? 0), 0) / totalPop
    : 0;
  return { ...region, totalPop, weightedWbi, areaCount: regionAreas.length };
}).sort((a, b) => a.weightedWbi - b.weightedWbi);
---

<BaseLayout
  title="Regional demographic overview"
  description={`Demographic composition by region across ${regions.length} regions and ${areas.length} local authorities.`}
>
  <h1>Regional demographic overview</h1>
  <p class="desc">Population-weighted White British share by region. Click a region for local authority detail.</p>

  <div class="region-grid">
    {regionStats.map((region) => (
      <div class="region-card">
        <span class="region-name">{region.regionName}</span>
        <span class="region-stat">{region.weightedWbi.toFixed(1)}%</span>
        <span class="region-detail">WBI (pop-weighted) &middot; {region.areaCount} areas &middot; Pop {(region.totalPop / 1_000_000).toFixed(1)}M</span>
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  h1 { font-family: "Sora", sans-serif; font-size: 1.8rem; font-weight: 800; margin: 0 0 0.5rem; }
  .desc { color: var(--muted); font-size: 0.92rem; margin: 0 0 1.5rem; }
  .region-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 0.75rem; }
  .region-card { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 1.5rem; display: flex; flex-direction: column; gap: 0.25rem; }
  .region-name { font-weight: 700; font-size: 1rem; color: var(--ink); }
  .region-stat { font-family: "Sora", sans-serif; font-size: 1.8rem; font-weight: 800; color: var(--accent); }
  .region-detail { font-size: 0.82rem; color: var(--muted); }
</style>
