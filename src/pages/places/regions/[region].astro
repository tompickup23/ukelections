---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import { getPublicPlaceAreas, getPublicPlaceRegions, buildPublicPlaceRegionSlug, slugifyAreaName } from "../../../lib/site";

const allAreas = getPublicPlaceAreas();
const regions = getPublicPlaceRegions();

export function getStaticPaths() {
  const regions = getPublicPlaceRegions();
  return regions.map((region) => ({
    params: { region: buildPublicPlaceRegionSlug(region.regionName) },
    props: { regionName: region.regionName }
  }));
}

const { regionName } = Astro.props;
const regionAreas = allAreas
  .filter(a => a.regionName === regionName)
  .sort((a, b) => (a.wbiPct2021 ?? 100) - (b.wbiPct2021 ?? 100));
const totalPop = regionAreas.reduce((s, a) => s + (a.population ?? 0), 0);
---

<BaseLayout
  title={`${regionName} — regional demographic profile`}
  description={`${regionName}: ${regionAreas.length} local authorities, population ${totalPop.toLocaleString()}. Ethnic composition projections to 2061.`}
>
  <Breadcrumbs items={[
    { label: "Home", href: "/" },
    { label: "Places", href: "/places/" },
    { label: regionName }
  ]} />

  <h1>{regionName}</h1>
  <p class="desc">{regionAreas.length} local authorities &middot; Population {(totalPop / 1_000_000).toFixed(1)}M</p>

  <div class="area-table">
    <div class="area-table-header">
      <span>Area</span><span>WBI 2021</span><span>WBI 2041</span><span>Population</span>
    </div>
    {regionAreas.map((area) => (
      <a href={`/places/${slugifyAreaName(area.areaName)}/`} class="area-row">
        <span class="area-name">{area.areaName}</span>
        <span class="area-wbi">{area.wbiPct2021?.toFixed(1) ?? "-"}%</span>
        <span class="area-wbi-proj">{area.wbiPct2041?.toFixed(1) ?? "-"}%</span>
        <span class="area-pop">{area.population?.toLocaleString() ?? "-"}</span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  h1 { font-family: "Sora", sans-serif; font-size: 1.8rem; font-weight: 800; margin: 0 0 0.25rem; }
  .desc { color: var(--muted); font-size: 0.92rem; margin: 0 0 1.5rem; }
  .area-table { max-width: 700px; }
  .area-table-header { display: grid; grid-template-columns: 1fr 80px 80px 100px; padding: 0.5rem 0.75rem; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); border-bottom: 1px solid var(--border-strong); }
  .area-row { display: grid; grid-template-columns: 1fr 80px 80px 100px; align-items: center; padding: 0.5rem 0.75rem; text-decoration: none; color: var(--ink); border-bottom: 1px solid var(--border); transition: background 120ms; }
  .area-row:hover { background: rgba(79, 70, 229, 0.06); }
  .area-name { font-weight: 600; font-size: 0.88rem; }
  .area-wbi { font-family: "Sora", sans-serif; font-weight: 700; color: var(--accent); font-size: 0.88rem; }
  .area-wbi-proj { font-family: "Sora", sans-serif; font-weight: 700; color: var(--coral); font-size: 0.88rem; }
  .area-pop { font-size: 0.82rem; color: var(--muted); }
</style>
