---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublicPlaceAreas, slugifyAreaName } from "../../lib/site";

const areas = getPublicPlaceAreas();
const sortedAreas = [...areas].sort((a, b) => (a.wbiPct2021 ?? 100) - (b.wbiPct2021 ?? 100));
---

<BaseLayout
  title="All places — demographic profiles"
  description={`Browse ${areas.length} local authority demographic profiles with ethnic projections to 2061.`}
>
  <h1 class="page-title">{areas.length} local authorities</h1>
  <p class="page-desc">Every area with demographic projections. Sorted by White British share (2021 Census, ascending).</p>

  <div class="area-search-wrapper">
    <input type="search" id="places-search" placeholder="Filter by name..." autocomplete="off" spellcheck="false" />
  </div>

  <div class="area-table" id="places-table">
    <div class="area-table-header">
      <span>Area</span><span>Region</span><span>WBI 2021</span><span>WBI 2041</span><span>Population</span>
    </div>
    {sortedAreas.map((area) => (
      <a href={`/places/${slugifyAreaName(area.areaName)}/`} class="area-row" data-name={area.areaName.toLowerCase()}>
        <span class="area-name">{area.areaName}</span>
        <span class="area-region">{area.regionName}</span>
        <span class="area-wbi">{area.wbiPct2021?.toFixed(1) ?? "-"}%</span>
        <span class="area-wbi-proj">{area.wbiPct2041?.toFixed(1) ?? "-"}%</span>
        <span class="area-pop">{area.population?.toLocaleString() ?? "-"}</span>
      </a>
    ))}
  </div>
</BaseLayout>

<script>
  const input = document.getElementById("places-search") as HTMLInputElement;
  const rows = document.querySelectorAll<HTMLAnchorElement>(".area-row");
  input?.addEventListener("input", () => {
    const q = input.value.toLowerCase();
    rows.forEach((row) => { row.style.display = (row.dataset.name?.includes(q)) ? "" : "none"; });
  });
</script>

<style>
  .page-title { font-family: "Sora", sans-serif; font-size: 1.8rem; font-weight: 800; margin: 0 0 0.5rem; }
  .page-desc { color: var(--muted); font-size: 0.92rem; margin: 0 0 1.5rem; }
  .area-search-wrapper { margin-bottom: 1rem; max-width: 400px; }
  .area-search-wrapper input { width: 100%; padding: 0.75rem 1rem; font-size: 0.95rem; font-family: "Manrope", sans-serif; color: var(--ink); background: var(--bg-soft); border: 2px solid var(--border-strong); border-radius: var(--radius-sm); outline: none; }
  .area-search-wrapper input:focus { border-color: var(--accent); box-shadow: 0 0 0 4px var(--accent-glow); }
  .area-table { max-width: 900px; }
  .area-table-header { display: grid; grid-template-columns: 1fr 120px 80px 80px 100px; padding: 0.5rem 0.75rem; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); border-bottom: 1px solid var(--border-strong); }
  .area-row { display: grid; grid-template-columns: 1fr 120px 80px 80px 100px; align-items: center; padding: 0.5rem 0.75rem; text-decoration: none; color: var(--ink); border-bottom: 1px solid var(--border); transition: background 120ms; }
  .area-row:hover { background: rgba(79, 70, 229, 0.06); }
  .area-name { font-weight: 600; font-size: 0.88rem; }
  .area-region { font-size: 0.82rem; color: var(--muted); }
  .area-wbi { font-family: "Sora", sans-serif; font-weight: 700; color: var(--accent); font-size: 0.88rem; }
  .area-wbi-proj { font-family: "Sora", sans-serif; font-weight: 700; color: var(--coral); font-size: 0.88rem; }
  .area-pop { font-size: 0.82rem; color: var(--muted); }
  @media (max-width: 640px) { .area-table-header, .area-row { grid-template-columns: 1fr 70px 70px; } .area-region, .area-pop { display: none; } }
</style>
