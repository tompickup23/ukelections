---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadMayHeadline, loadGeHeadline, countdownToMay, shortPartyLabel } from "../lib/siteData";
import { partyColour } from "../lib/predictions";

const may = loadMayHeadline();
const ge = loadGeHeadline();
const cd = countdownToMay();
---

<BaseLayout title="All forecasts" description="Every UK election forecast on the site, in one place.">
  <section class="page-hero">
    <p class="eyebrow">All forecasts</p>
    <h1>Every UK election, forecast.</h1>
    <p class="lede">
      Four election families, one model, one accuracy record. Pick the contest you're interested in.
    </p>
  </section>

  <section class="section">
    <div class="feature-list">
      <article>
        <h3>May 7 — English councils + mayoralties</h3>
        <p>
          {may.council_count} councils, {may.ward_count.toLocaleString()} wards, {may.seats_total.toLocaleString()} seats.
          {cd.has_passed ? "Live tracking." : `${cd.days_until} days to go.`}
        </p>
        <p><a href="/forecasts/may-2026/">See the May 7 forecast →</a></p>
      </article>
      <article>
        <h3>Senedd Cymru 2026</h3>
        <p>The first election under the new closed-list PR system: 16 super-constituencies × 6 list seats = 96 seats.</p>
        <p><a href="/forecasts/senedd-2026/">See the Senedd forecast →</a></p>
      </article>
      <article>
        <h3>Scottish Parliament 2026</h3>
        <p>73 constituency seats (FPTP) + 56 regional list seats (d'Hondt) = 129 seats.</p>
        <p><a href="/forecasts/holyrood-2026/">See the Holyrood forecast →</a></p>
      </article>
      <article>
        <h3>UK general election</h3>
        <p>
          {ge.total_seats.toLocaleString()} constituencies. Refreshed daily.
          {ge.seat_tallies[0] ? ` Headline: ${shortPartyLabel(ge.seat_tallies[0].party)} ${ge.seat_tallies[0].seats} seats.` : ""}
        </p>
        <p><a href="/forecasts/general-election/">See the GE forecast →</a></p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <p class="eyebrow">Find your specific ward or constituency</p>
      <h2>Search by postcode</h2>
    </div>
    <p>
      Type a postcode, town name, or council name and we'll route you to the exact contest you'll be voting in.
    </p>
    <p><a class="button primary" href="/your-area/">Find my ward →</a></p>
  </section>
</BaseLayout>
