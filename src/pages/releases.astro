---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  DEFAULT_DESCRIPTION,
  DEFAULT_SOCIAL_IMAGE_PATH,
  RELEASES,
  buildAbsoluteUrl,
  buildReleaseCollectionStructuredData
} from "../lib/site";

const description = "Release diary for UK Elections build, data, and model updates.";
const structuredData = buildReleaseCollectionStructuredData(RELEASES, {
  canonicalUrl: buildAbsoluteUrl("/releases/"),
  description,
  socialImageUrl: buildAbsoluteUrl(DEFAULT_SOCIAL_IMAGE_PATH)
});
---

<BaseLayout title="Releases" description={description} structuredData={structuredData}>
  <section class="page-hero">
    <p class="eyebrow">Releases</p>
    <h1>Build log and model changes.</h1>
    <p class="lede">{DEFAULT_DESCRIPTION}</p>
  </section>

  <section class="release-list" aria-label="Release diary">
    {RELEASES.map((release) => (
      <article>
        <time datetime={release.date}>{release.date}</time>
        <h2>{release.title}</h2>
        <p>{release.summary}</p>
      </article>
    ))}
  </section>
</BaseLayout>
