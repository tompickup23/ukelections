---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy" description="Privacy statement for UK Elections.">
  <section class="page-hero">
    <p class="eyebrow">Privacy</p>
    <h1>No cookies. No analytics. No accounts.</h1>
  </section>
  <section class="section prose-block">
    <p>UK Elections is currently a static site. It does not set cookies, run analytics, collect account data, or store form submissions.</p>
    <p>When postcode lookup is enabled, the request path and privacy handling will be documented here before release.</p>
  </section>
</BaseLayout>
