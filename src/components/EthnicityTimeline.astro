---
/**
 * Animated stacked bar chart showing ethnic composition change over decades.
 * Shows absolute or percentage breakdown for each census/projection year.
 */
interface EthnicSnapshot {
  year: string;
  groups: {
    white_british: number;
    white_other: number;
    asian: number;
    black: number;
    mixed: number;
    other: number;
  };
  isProjection: boolean;
}

interface Props {
  timeline: EthnicSnapshot[];
  areaName: string;
}

const { timeline, areaName } = Astro.props;

const groupLabels: Record<string, string> = {
  white_british: "White British",
  white_other: "White Other",
  asian: "Asian",
  black: "Black",
  mixed: "Mixed",
  other: "Other"
};

const groupColors: Record<string, string> = {
  white_british: "#06b6d4",
  white_other: "#8b9cb3",
  asian: "#f59e0b",
  black: "#a78bfa",
  mixed: "#10b981",
  other: "#6b7280"
};

const groupKeys = ["white_british", "white_other", "asian", "black", "mixed", "other"] as const;

// Build bar data
const barData = timeline.map(snap => {
  const total = groupKeys.reduce((sum, k) => sum + snap.groups[k], 0);
  return {
    year: snap.year,
    isProjection: snap.isProjection,
    segments: groupKeys.map(k => ({
      key: k,
      label: groupLabels[k],
      color: groupColors[k],
      pct: total > 0 ? snap.groups[k] : 0,
      value: snap.groups[k]
    })).filter(s => s.pct > 1) // hide < 1%
  };
});
---

<figure class="eth-timeline">
  <div class="eth-timeline-head">
    <h3>Ethnic composition: {areaName}</h3>
    <p class="tiny">Census 2011, Census 2021, then Hamilton-Perry projections to 2051. Percentages.</p>
  </div>

  <div class="eth-bars">
    {barData.map(bar => (
      <div class={`eth-bar-row ${bar.isProjection ? "eth-projected" : ""}`}>
        <span class="eth-year">
          {bar.year}
          {bar.isProjection && <span class="eth-proj-badge">proj</span>}
        </span>
        <div class="eth-bar-track">
          {bar.segments.map(seg => (
            <div
              class="eth-segment"
              style={`width: ${seg.pct}%; background: ${seg.color};`}
              title={`${seg.label}: ${seg.pct.toFixed(1)}%`}
            >
              {seg.pct >= 8 && (
                <span class="eth-seg-label">{seg.pct.toFixed(0)}%</span>
              )}
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div class="eth-legend">
    {groupKeys.map(k => (
      <span class="eth-legend-item">
        <span class="eth-legend-dot" style={`background: ${groupColors[k]}`}></span>
        {groupLabels[k]}
      </span>
    ))}
  </div>
</figure>

<style>
  .eth-timeline {
    padding: 1.25rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--panel);
  }
  .eth-timeline-head h3 {
    font-family: "Sora", sans-serif;
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.15rem;
    color: var(--ink);
  }
  .eth-bars {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .eth-bar-row {
    display: grid;
    grid-template-columns: 70px 1fr;
    align-items: center;
    gap: 0.5rem;
  }
  .eth-year {
    font-family: "Sora", sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .eth-proj-badge {
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-3);
    background: rgba(245, 158, 11, 0.12);
    padding: 0.1rem 0.3rem;
    border-radius: 4px;
  }
  .eth-bar-track {
    display: flex;
    height: 32px;
    border-radius: 6px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
  }
  .eth-segment {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 2px;
    transition: width 400ms ease;
    position: relative;
  }
  .eth-seg-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: rgba(0, 0, 0, 0.7);
    text-shadow: 0 0 3px rgba(255, 255, 255, 0.3);
    pointer-events: none;
  }
  .eth-projected {
    opacity: 0.85;
  }
  .eth-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 0.75rem;
  }
  .eth-legend-item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.78rem;
    color: var(--muted);
  }
  .eth-legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 3px;
    flex-shrink: 0;
  }
  @media (max-width: 640px) {
    .eth-bar-row { grid-template-columns: 55px 1fr; }
    .eth-bar-track { height: 26px; }
    .eth-year { font-size: 0.78rem; }
    .eth-seg-label { font-size: 0.62rem; }
  }
</style>
