---
// Teaser promoting asylumstats.co.uk from UK Demographics.
// Shows the headline asylum-spend numbers with a mini bar visualization
// and a prominent CTA. Update quarterly alongside asylumstats' own home page.
//
// Source: Home Office asylum accommodation factsheet (daily cost),
// NAO Investigation into Asylum Accommodation (Nov 2024, 10-year forecast),
// HMRC projected taxpayers 2024-25 (34.1M).

const DAILY_COST_GBP = 5_770_000;
const PER_TAXPAYER_MIN_GBP = 155;
const TEN_YEAR_GBP = 15_300_000_000;
const HOTEL_RESIDENTS = 30_912; // Q4 2025 stock
const AWAITING_DECISION = 98_112; // Q4 2025

// Mini bar viz — spend allocation (approx split from NAO + HO factsheet)
const bars = [
  { label: "Hotels", pct: 44, color: "var(--coral)" },
  { label: "Dispersed accom.", pct: 28, color: "var(--accent-3)" },
  { label: "Processing & admin", pct: 16, color: "var(--accent)" },
  { label: "Local auth. grants", pct: 8, color: "var(--accent-2)" },
  { label: "Other", pct: 4, color: "var(--muted)" },
];

function fmtGbp(n: number) {
  if (n >= 1_000_000_000) return `£${(n / 1_000_000_000).toFixed(1)}B`;
  if (n >= 1_000_000) return `£${(n / 1_000_000).toFixed(2)}M`;
  return `£${n.toLocaleString("en-GB")}`;
}
---

<section class="sister-teaser shell" aria-labelledby="sister-teaser-title">
  <div class="st-inner">
    <div class="st-head">
      <span class="st-eyebrow">Sister site &middot; asylumstats.co.uk</span>
      <h2 class="st-title" id="sister-teaser-title">
        Where YOUR money goes — the asylum accommodation bill
      </h2>
      <p class="st-desc">
        We track the demographic transformation here.
        Over on <strong>asylumstats.co.uk</strong> we track the fiscal bill.
        Same government data. Two lenses. Follow both.
      </p>
    </div>

    <div class="st-grid">
      <!-- Top-line stats -->
      <div class="st-stats">
        <div class="st-stat st-stat--hero">
          <span class="st-stat-value">{fmtGbp(DAILY_COST_GBP)}</span>
          <span class="st-stat-label">per day</span>
          <span class="st-stat-context">Home Office asylum accommodation, 2024&ndash;25 average</span>
        </div>
        <div class="st-stat">
          <span class="st-stat-value">£{PER_TAXPAYER_MIN_GBP}+</span>
          <span class="st-stat-label">per taxpayer per year</span>
          <span class="st-stat-context">Minimum — hotels + processing + local auth + border + NHS</span>
        </div>
        <div class="st-stat">
          <span class="st-stat-value">{fmtGbp(TEN_YEAR_GBP)}</span>
          <span class="st-stat-label">over 10 years</span>
          <span class="st-stat-context">NAO forecast, contract rose from £4.5B to £15.3B</span>
        </div>
      </div>

      <!-- Mini bar visualization -->
      <div class="st-viz">
        <span class="st-viz-title">Annual spend allocation (approx.)</span>
        <div class="st-bars">
          {bars.map((b) => (
            <div class="st-bar-row">
              <span class="st-bar-label">{b.label}</span>
              <span class="st-bar-track">
                <span class="st-bar-fill" style={`width: ${b.pct}%; background: ${b.color};`}></span>
              </span>
              <span class="st-bar-pct">{b.pct}%</span>
            </div>
          ))}
        </div>
        <div class="st-viz-caption">
          {HOTEL_RESIDENTS.toLocaleString("en-GB")} in hotels &middot;
          {AWAITING_DECISION.toLocaleString("en-GB")} awaiting a decision &middot;
          Q4 2025
        </div>
      </div>
    </div>

    <div class="st-cta-row">
      <a
        href="https://asylumstats.co.uk"
        class="st-cta-btn"
        target="_blank"
        rel="noopener"
      >
        Follow the money &rarr; asylumstats.co.uk
      </a>
      <a
        href="https://asylumstats.co.uk/findings/true-cost-of-asylum/"
        class="st-cta-link"
        target="_blank"
        rel="noopener"
      >
        Read the true-cost breakdown &rarr;
      </a>
    </div>
  </div>
</section>

<style>
  .sister-teaser {
    margin-top: 3rem;
    padding: 2.5rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, rgba(6, 182, 212, 0.05) 0%, transparent 70%);
    position: relative;
    overflow: hidden;
  }
  .sister-teaser::before {
    content: "";
    position: absolute;
    top: -30%;
    right: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(6, 182, 212, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .st-inner { position: relative; z-index: 1; }

  .st-head { max-width: 760px; margin-bottom: 1.5rem; }
  .st-eyebrow {
    font-family: "Sora", sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #06b6d4;
    display: inline-block;
    padding: 0.3rem 0.6rem;
    border: 1px solid rgba(6, 182, 212, 0.3);
    border-radius: 999px;
    background: rgba(6, 182, 212, 0.08);
    margin-bottom: 0.75rem;
  }
  .st-title {
    font-family: "Sora", sans-serif;
    font-size: clamp(1.25rem, 2.8vw, 1.65rem);
    font-weight: 800;
    color: var(--ink);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .st-desc {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.55;
    margin: 0;
  }
  .st-desc strong { color: #06b6d4; font-weight: 700; }

  .st-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: stretch;
  }

  /* Stats column */
  .st-stats {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .st-stat {
    background: var(--panel);
    border: 1px solid var(--border);
    border-left: 3px solid var(--coral);
    border-radius: var(--radius-sm);
    padding: 1rem 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .st-stat--hero {
    border-left-width: 4px;
    background: linear-gradient(180deg, rgba(239, 68, 68, 0.05) 0%, var(--panel) 100%);
  }
  .st-stat-value {
    font-family: "Sora", sans-serif;
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--coral);
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .st-stat--hero .st-stat-value { font-size: 2.4rem; }
  .st-stat-label {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--ink);
    margin-top: 0.15rem;
  }
  .st-stat-context {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.4;
    margin-top: 0.2rem;
  }

  /* Visualization column */
  .st-viz {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .st-viz-title {
    font-family: "Sora", sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
  }
  .st-bars {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .st-bar-row {
    display: grid;
    grid-template-columns: 130px 1fr 42px;
    align-items: center;
    gap: 0.6rem;
  }
  .st-bar-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .st-bar-track {
    display: block;
    height: 14px;
    background: rgba(6, 182, 212, 0.08);
    border-radius: 3px;
    overflow: hidden;
  }
  .st-bar-fill {
    display: block;
    height: 100%;
    border-radius: 3px;
    min-width: 4px;
    transition: width 600ms ease;
  }
  .st-bar-pct {
    font-family: "Sora", sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--muted);
    text-align: right;
  }
  .st-viz-caption {
    margin-top: 0.25rem;
    font-size: 0.75rem;
    color: var(--muted);
    opacity: 0.8;
    line-height: 1.4;
  }

  .st-cta-row {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .st-cta-btn {
    display: inline-block;
    padding: 0.75rem 1.25rem;
    font-size: 0.95rem;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%);
    border-radius: 8px;
    text-decoration: none;
    transition: transform 180ms, box-shadow 180ms;
    box-shadow: 0 2px 12px rgba(6, 182, 212, 0.25);
  }
  .st-cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(6, 182, 212, 0.4);
  }
  .st-cta-link {
    font-size: 0.88rem;
    font-weight: 600;
    color: #06b6d4;
    text-decoration: none;
  }
  .st-cta-link:hover { text-decoration: underline; }

  @media (max-width: 760px) {
    .st-grid { grid-template-columns: 1fr; gap: 1rem; }
    .st-stat--hero .st-stat-value { font-size: 2rem; }
    .st-bar-row { grid-template-columns: 110px 1fr 38px; }
    .st-bar-label { font-size: 0.78rem; }
    .st-cta-row { flex-direction: column; align-items: flex-start; }
    .st-cta-btn { width: 100%; text-align: center; }
  }
</style>
