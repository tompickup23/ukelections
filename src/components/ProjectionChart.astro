---
/**
 * Multi-line SVG projection chart with optional confidence band.
 * Shows ethnic/religion/nativity composition trajectories over time.
 */
interface LineData {
  label: string;
  color: string;
  points: Array<{ year: number; value: number }>;
}

interface BandPoint {
  year: number;
  low: number;
  high: number;
}

interface Props {
  title: string;
  lines: LineData[];
  confidenceBand?: BandPoint[];
  nowYear?: number;
  yLabel?: string;
  height?: number;
}

const { title, lines, confidenceBand, nowYear = 2021, yLabel = "%", height: chartHeight = 220 } = Astro.props;

const width = 560;
const height = chartHeight;
const pad = { top: 14, right: 16, bottom: 34, left: 42 };
const uw = width - pad.left - pad.right;
const uh = height - pad.top - pad.bottom;

// Compute scales from all data
const allYears = lines.flatMap(l => l.points.map(p => p.year));
const allValues = lines.flatMap(l => l.points.map(p => p.value));
if (confidenceBand) {
  allValues.push(...confidenceBand.map(b => b.low), ...confidenceBand.map(b => b.high));
}
const minYear = Math.min(...allYears);
const maxYear = Math.max(...allYears);
const yearRange = Math.max(maxYear - minYear, 1);
const maxVal = Math.min(100, Math.max(...allValues) + 5);
const minVal = Math.max(0, Math.min(...allValues) - 5);
const valRange = Math.max(maxVal - minVal, 1);

function x(year: number) { return pad.left + ((year - minYear) / yearRange) * uw; }
function y(val: number) { return pad.top + uh - ((val - minVal) / valRange) * uh; }

// Y-axis ticks
const tickCount = 5;
const ticks = Array.from({ length: tickCount }, (_, i) => minVal + (valRange / (tickCount - 1)) * i);

// Build SVG paths
function buildLinePath(points: Array<{ year: number; value: number }>): string {
  return points.map((p, i) => `${i === 0 ? "M" : "L"} ${x(p.year).toFixed(1)} ${y(p.value).toFixed(1)}`).join(" ");
}

function buildBandPath(band: BandPoint[]): string {
  const upper = band.map(b => `${x(b.year).toFixed(1)} ${y(b.high).toFixed(1)}`);
  const lower = [...band].reverse().map(b => `${x(b.year).toFixed(1)} ${y(b.low).toFixed(1)}`);
  return `M ${upper.join(" L ")} L ${lower.join(" L ")} Z`;
}

// Year labels
const labelYears = [minYear, nowYear, ...([2031, 2041, 2051].filter(yr => yr <= maxYear && yr > nowYear))].filter((v, i, a) => a.indexOf(v) === i);
---

<figure class="viz-card projection-chart">
  <div class="viz-head">
    <h3>{title}</h3>
  </div>
  <svg viewBox={`0 0 ${width} ${height}`} role="img" aria-label={title}>
    <!-- Grid -->
    {ticks.map(tick => (
      <>
        <line x1={pad.left} y1={y(tick)} x2={width - pad.right} y2={y(tick)}
              stroke="rgba(255,255,255,0.06)" stroke-width="1" stroke-dasharray="4 6" />
        <text x={pad.left - 6} y={y(tick) + 4} text-anchor="end" class="proj-tick">{Math.round(tick)}</text>
      </>
    ))}

    <!-- Y axis label -->
    <text x={8} y={pad.top + uh / 2} text-anchor="middle" transform={`rotate(-90 8 ${pad.top + uh / 2})`} class="proj-axis-label">{yLabel}</text>

    <!-- Confidence band (shaded area) -->
    {confidenceBand && confidenceBand.length > 0 && (
      <path d={buildBandPath(confidenceBand)} fill="rgba(6, 182, 212, 0.12)" />
    )}

    <!-- Now line -->
    <line x1={x(nowYear)} y1={pad.top} x2={x(nowYear)} y2={pad.top + uh}
          stroke="rgba(255,255,255,0.2)" stroke-width="1" stroke-dasharray="3 4" />
    <text x={x(nowYear)} y={pad.top - 3} text-anchor="middle" class="proj-now-label">Census 2021</text>

    <!-- 2051 boundary (if 2061 data exists) -->
    {maxYear > 2051 && (
      <>
        <line x1={x(2051)} y1={pad.top} x2={x(2051)} y2={pad.top + uh}
              stroke="rgba(245,158,11,0.2)" stroke-width="1" stroke-dasharray="2 4" />
        <text x={x(2051)} y={pad.top + uh + 20} text-anchor="middle" class="proj-now-label" fill="rgba(245,158,11,0.5)">Illustrative</text>
      </>
    )}

    <!-- Lines -->
    {lines.map(line => (
      <>
        <path d={buildLinePath(line.points)} fill="none" stroke={line.color}
              stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" />
        {/* End label */}
        {line.points.length > 0 && (
          <text x={x(line.points[line.points.length - 1].year) + 4}
                y={y(line.points[line.points.length - 1].value) + 4}
                class="proj-line-label" fill={line.color}>
            {line.label} {line.points[line.points.length - 1].value.toFixed(0)}%
          </text>
        )}
        {/* End dot */}
        {line.points.length > 0 && (
          <circle cx={x(line.points[line.points.length - 1].year)}
                  cy={y(line.points[line.points.length - 1].value)}
                  r="3.5" fill={line.color} />
        )}
      </>
    ))}

    <!-- X axis labels -->
    {labelYears.map(yr => (
      <text x={x(yr)} y={height - 8} text-anchor="middle" class="proj-year-label">{yr}</text>
    ))}
  </svg>

  <!-- Legend -->
  <div class="proj-legend">
    {lines.map(line => (
      <span class="proj-legend-item">
        <span class="proj-legend-swatch" style={`background: ${line.color}`}></span>
        {line.label}
      </span>
    ))}
    {confidenceBand && <span class="proj-legend-item"><span class="proj-legend-swatch" style="background: rgba(6, 182, 212, 0.3)"></span> 80% CI</span>}
  </div>
</figure>

<style>
  .projection-chart svg { width: 100%; height: auto; display: block; }
  .proj-tick { font-size: 11px; fill: rgba(255,255,255,0.45); font-family: "Sora", sans-serif; }
  .proj-axis-label { font-size: 10px; fill: rgba(255,255,255,0.35); font-family: "Sora", sans-serif; }
  .proj-now-label { font-size: 10px; fill: rgba(255,255,255,0.45); font-family: "Sora", sans-serif; }
  .proj-line-label { font-size: 10px; font-family: "Sora", sans-serif; font-weight: 600; }
  .proj-year-label { font-size: 11px; fill: rgba(255,255,255,0.55); font-family: "Sora", sans-serif; }
  .proj-legend { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 0.5rem; }
  .proj-legend-item { display: flex; align-items: center; gap: 0.3rem; font-size: 0.82rem; color: var(--muted); }
  .proj-legend-swatch { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }
</style>
