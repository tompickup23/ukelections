---
/**
 * Economic profile section for place pages.
 * Shows worklessness, benefits, education, deprivation, income.
 */
interface EconomicData {
  worklessness?: { total: number; white?: number; ethnicMinority?: number };
  benefits?: { ucTotal: number; jsaTotal?: number; rate: number };
  education?: { gcse5Plus?: number; nvq4Plus?: number; noQualifications?: number };
  deprivation?: { imdRank: number; imdDecile: number };
  medianIncome?: number;
  economicInactivity?: { total: number };
}

interface Props {
  data: EconomicData;
  areaName: string;
}

const { data, areaName } = Astro.props;

function fmt(n: number | undefined, suffix = ""): string {
  if (n === undefined || n === null) return "—";
  return `${n.toLocaleString()}${suffix}`;
}

function pct(n: number | undefined): string {
  if (n === undefined || n === null) return "—";
  return `${n.toFixed(1)}%`;
}

const hasWorklessness = data.worklessness && data.worklessness.total > 0;
const hasBenefits = data.benefits && data.benefits.rate > 0;
const hasEducation = data.education;
const hasDeprivation = data.deprivation;
---

<div class="econ-profile">
  <div class="econ-grid">
    {hasWorklessness && (
      <div class="econ-card">
        <span class="econ-label">Worklessness rate</span>
        <span class="econ-value">{pct(data.worklessness!.total)}</span>
        {data.worklessness!.white !== undefined && (
          <div class="econ-breakdown">
            <span>White: {pct(data.worklessness!.white)}</span>
            <span>Ethnic minority: {pct(data.worklessness!.ethnicMinority)}</span>
          </div>
        )}
      </div>
    )}

    {hasBenefits && (
      <div class="econ-card">
        <span class="econ-label">Benefits claimants</span>
        <span class="econ-value">{pct(data.benefits!.rate)}</span>
        <div class="econ-breakdown">
          <span>UC: {fmt(data.benefits!.ucTotal)}</span>
          {data.benefits!.jsaTotal !== undefined && <span>JSA: {fmt(data.benefits!.jsaTotal)}</span>}
        </div>
      </div>
    )}

    {data.medianIncome !== undefined && (
      <div class="econ-card">
        <span class="econ-label">Median income</span>
        <span class="econ-value">£{data.medianIncome.toLocaleString()}</span>
      </div>
    )}

    {hasDeprivation && (
      <div class="econ-card">
        <span class="econ-label">Deprivation (IMD)</span>
        <span class="econ-value">Decile {data.deprivation!.imdDecile}</span>
        <span class="econ-breakdown">
          <span>Rank: {fmt(data.deprivation!.imdRank)} of 317</span>
        </span>
      </div>
    )}

    {hasEducation && (
      <div class="econ-card">
        <span class="econ-label">Educational attainment</span>
        {data.education!.gcse5Plus !== undefined && (
          <div class="econ-row">
            <span>GCSE 5+ A*-C</span>
            <span class="econ-row-value">{pct(data.education!.gcse5Plus)}</span>
          </div>
        )}
        {data.education!.nvq4Plus !== undefined && (
          <div class="econ-row">
            <span>NVQ4+ (degree)</span>
            <span class="econ-row-value">{pct(data.education!.nvq4Plus)}</span>
          </div>
        )}
        {data.education!.noQualifications !== undefined && (
          <div class="econ-row">
            <span>No qualifications</span>
            <span class="econ-row-value">{pct(data.education!.noQualifications)}</span>
          </div>
        )}
      </div>
    )}

    {data.economicInactivity && (
      <div class="econ-card">
        <span class="econ-label">Economic inactivity</span>
        <span class="econ-value">{pct(data.economicInactivity.total)}</span>
      </div>
    )}
  </div>
</div>

<style>
  .econ-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.75rem;
  }
  .econ-card {
    padding: 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--panel);
  }
  .econ-label {
    display: block;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin-bottom: 0.35rem;
  }
  .econ-value {
    display: block;
    font-family: "Sora", sans-serif;
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--ink);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 0.25rem;
  }
  .econ-breakdown {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    font-size: 0.82rem;
    color: var(--muted);
  }
  .econ-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.3rem 0;
    font-size: 0.85rem;
    color: var(--ink-soft);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }
  .econ-row:last-child { border-bottom: none; }
  .econ-row-value {
    font-family: "Sora", sans-serif;
    font-weight: 700;
    color: var(--ink);
  }
  @media (max-width: 640px) {
    .econ-grid { grid-template-columns: repeat(2, 1fr); }
    .econ-value { font-size: 1.15rem; }
  }
</style>
