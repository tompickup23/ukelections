---
interface Props {
  url: string;
  title: string;
  text: string;
  compact?: boolean;
}

const { url, title, text, compact = false } = Astro.props;
const xUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`;
---

{compact ? (
  <div class="share-compact">
    <button type="button" data-share data-url={url} data-title={title} data-text={text} class="share-icon-btn" aria-label="Share">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
    </button>
    <a href={xUrl} target="_blank" rel="noopener" class="share-icon-btn" aria-label="Share on X">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </a>
  </div>
) : (
  <div class="share-group">
    <button type="button" data-share data-url={url} data-title={title} data-text={text} class="cta-btn cta-btn--secondary">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
      <span data-share-label>Share</span>
    </button>
    <a href={xUrl} target="_blank" rel="noopener" class="cta-btn cta-btn--secondary">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      Share on X
    </a>
  </div>
)}

<script>
  document.querySelectorAll("[data-share]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const { url, title, text } = (btn as HTMLElement).dataset;
      const label = btn.querySelector("[data-share-label]");
      try {
        if (navigator.share) {
          await navigator.share({ url, title, text });
        } else {
          await navigator.clipboard.writeText(url ?? window.location.href);
          if (label) {
            label.textContent = "Copied!";
            setTimeout(() => (label.textContent = "Share"), 2000);
          }
        }
      } catch {
        /* user cancelled share dialog */
      }
    });
  });
</script>

<style>
  .share-group {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .share-compact {
    display: flex;
    gap: 0.35rem;
  }
  .share-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--panel-soft);
    color: var(--muted);
    cursor: pointer;
    transition: color 180ms, border-color 180ms, background 180ms;
    text-decoration: none;
  }
  .share-icon-btn:hover {
    color: var(--ink);
    border-color: var(--accent);
    background: rgba(6, 182, 212, 0.08);
  }
</style>
