---
import { NAV_ITEMS } from "../lib/site";

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  return pathname === href || pathname.startsWith(href);
}
---

<header class="site-header">
  <a class="brand" href="/" aria-label="UK Elections home">
    <span class="brand-mark" aria-hidden="true">
      <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="7" y="5" width="22" height="26" rx="4" fill="#ffffff" stroke="#111827" stroke-width="2" />
        <path d="M12 12h12M12 18h12" stroke="#111827" stroke-width="2" stroke-linecap="round" />
        <path d="m12 25 4 3 9-11" stroke="#138a52" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
    <span class="brand-copy">
      <span>UK Elections</span>
      <small>Contest data. Forecasts. Backtests.</small>
    </span>
  </a>

  <nav class="site-nav" aria-label="Primary">
    {NAV_ITEMS.map((item) => (
      <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
        {item.label}
      </a>
    ))}
  </nav>
</header>
