---
import RegionTileMap from "./RegionTileMap.astro";
import type { RegionMapView } from "../lib/region-map-explorer";

interface Props {
  id?: string;
  title: string;
  intro: string;
  views: RegionMapView[];
  defaultViewId?: string;
  compact?: boolean;
  labelMode?: "all" | "essential" | "selected";
  interactionMode?: "navigate" | "select";
  showSummary?: boolean;
  summaryMode?: "side" | "overlay";
  legendMode?: "card" | "overlay";
  fitMode?: "fill-width" | "contain";
}

const {
  id,
  title,
  intro,
  views,
  defaultViewId,
  compact = false,
  labelMode,
  interactionMode = "navigate",
  showSummary = true,
  summaryMode = "side",
  legendMode = "card",
  fitMode = "fill-width"
} = Astro.props;
const fallbackViewId = defaultViewId ?? views[0]?.id ?? null;
const activeView = views.find((view) => view.id === fallbackViewId) ?? views[0] ?? null;
const mapActionLabel = interactionMode === "select" ? "Select a region" : "Click a region to open it";
const mapSelectionLabel =
  interactionMode === "select"
    ? "Selected region updates the panel"
    : "Selected region summary updates below the map";
---

{activeView && (
  <section
    class:list={[
      "region-map-explorer",
      compact && "is-compact",
      legendMode === "overlay" && "is-legend-overlay"
    ]}
    data-region-map-explorer
    data-initial-view={activeView.id}
    id={id}
  >
    {!compact && (
      <div class="region-map-explorer-head">
        <div>
          <h3>{title}</h3>
          <p class="lede">{intro}</p>
        </div>
        <div class="region-map-controls" role="toolbar" aria-label="Regional map metric">
          {views.map((view) => (
            <button
              type="button"
              class:list={["chip", view.tone ?? "accent", view.id === activeView.id && "is-active"]}
              data-region-map-view-button={view.id}
              data-region-map-legend-title={view.legendTitle}
              data-region-map-legend-body={view.legendBody}
              aria-pressed={view.id === activeView.id ? "true" : "false"}
            >
              {view.label}
            </button>
          ))}
        </div>
      </div>
    )}

    <article class:list={["region-map-legend", legendMode === "overlay" && "is-overlay"]} data-region-map-legend>
      {compact && (
        <div class="region-map-legend-top">
          <div class="region-map-controls" role="toolbar" aria-label="Regional map metric">
            {views.map((view) => (
              <button
                type="button"
                class:list={["chip", view.tone ?? "accent", view.id === activeView.id && "is-active"]}
                data-region-map-view-button={view.id}
                data-region-map-button-legend-title={view.legendTitle}
                data-region-map-button-legend-body={view.legendBody}
                aria-pressed={view.id === activeView.id ? "true" : "false"}
              >
                {view.label}
              </button>
            ))}
          </div>
        </div>
      )}
      <div class="region-map-legend-swatch" data-region-map-legend-swatch data-tone={activeView.tone ?? "accent"}>
        <span>Lower</span>
        <span>Higher</span>
      </div>
      <div class="region-map-legend-copy">
        <strong data-region-map-active-legend-title>{compact ? "Scale first" : activeView.legendTitle}</strong>
        {!compact && <p class="tiny" data-region-map-active-legend-body>{activeView.legendBody}</p>}
      </div>
      {!compact && (
        <div class="chip-row">
          <span class="chip accent">{mapActionLabel}</span>
          <span class="chip">{mapSelectionLabel}</span>
        </div>
      )}
    </article>

    {views.map((view) => (
      <div
        data-region-map-view={view.id}
        hidden={view.id !== activeView.id}
        aria-hidden={view.id !== activeView.id ? "true" : "false"}
        inert={view.id !== activeView.id ? true : undefined}
      >
        <RegionTileMap
          items={view.items}
          title={view.title}
          description={view.description}
          valueLabel={view.valueLabel}
          highlightRegion={view.highlightRegion}
          highlightRegions={view.highlightRegions}
          summaries={view.summaries}
          tone={view.tone}
          compact={compact}
          labelMode={labelMode}
          interactionMode={interactionMode}
          showSummary={showSummary}
          summaryMode={summaryMode}
          fitMode={fitMode}
        />
      </div>
    ))}
  </section>
)}

<script>
  type RegionMapRootElement = HTMLElement & {
    __updateRegionMapSummary?: (regionName: string, trigger?: string) => void;
    __fitRegionMap?: () => void;
  };
  type RegionMapChangeDetail = {
    regionName?: string;
    trigger?: string;
  };
  const windowWithRegionMapExplorerFlag = window as Window & { __ukdRegionMapExplorerInit?: boolean };

  if (!windowWithRegionMapExplorerFlag.__ukdRegionMapExplorerInit) {
    windowWithRegionMapExplorerFlag.__ukdRegionMapExplorerInit = true;

    const activateView = (root: HTMLElement, viewId: string) => {
      const buttons = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-region-map-view-button]"));
      const panels = Array.from(root.querySelectorAll<HTMLElement>("[data-region-map-view]"));
      const targetPanel = panels.find((panel) => panel.dataset.regionMapView === viewId) ?? panels[0];
      const targetButton =
        buttons.find((button) => button.dataset.regionMapViewButton === targetPanel?.dataset.regionMapView) ?? buttons[0];

      if (!targetPanel || !targetButton) {
        return;
      }

      for (const button of buttons) {
        const isActive = button.dataset.regionMapViewButton === targetPanel.dataset.regionMapView;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", isActive ? "true" : "false");
      }

      for (const panel of panels) {
        const isActive = panel === targetPanel;
        panel.hidden = !isActive;
        panel.setAttribute("aria-hidden", isActive ? "false" : "true");

        if (isActive) {
          panel.removeAttribute("inert");
        } else {
          panel.setAttribute("inert", "");
        }
      }

      const legendTitle = root.querySelector<HTMLElement>("[data-region-map-active-legend-title]");
      const legendBody = root.querySelector<HTMLElement>("[data-region-map-active-legend-body]");
      const legendSwatch = root.querySelector<HTMLElement>("[data-region-map-legend-swatch]");

      if (legendTitle) {
        legendTitle.textContent = root.classList.contains("is-compact")
          ? "Scale first"
          : targetButton.dataset.regionMapButtonLegendTitle ?? "Read the region map";
      }

      if (legendBody) {
        legendBody.textContent =
          targetButton.dataset.regionMapButtonLegendBody ?? "Use the active metric to decide which regional page to open next.";
      }

      if (legendSwatch) {
        legendSwatch.dataset.tone = targetPanel.dataset.regionMapTone ?? "accent";
      }

      const selectedRegion = root.dataset.regionMapSelectedRegion;
      const activeRegionMap = targetPanel.querySelector<RegionMapRootElement>("[data-region-map-root]");

      if (selectedRegion && activeRegionMap?.__updateRegionMapSummary) {
        activeRegionMap.__updateRegionMapSummary(selectedRegion, "view");
      }

      activeRegionMap?.__fitRegionMap?.();
    };

    for (const root of document.querySelectorAll<HTMLElement>("[data-region-map-explorer]")) {
      if (root.dataset.regionMapExplorerReady === "true") {
        continue;
      }

      root.dataset.regionMapExplorerReady = "true";
      root.addEventListener("region-map-change", (event) => {
        const customEvent = event as CustomEvent<RegionMapChangeDetail>;
        const regionName = customEvent.detail?.regionName;

        if (regionName) {
          root.dataset.regionMapSelectedRegion = regionName;
        }
      });

      const panels = Array.from(root.querySelectorAll<HTMLElement>("[data-region-map-view]"));

      for (const panel of panels) {
        const regionMapFigure = panel.querySelector<HTMLElement>("[data-region-map-root]");
        panel.dataset.regionMapTone = regionMapFigure?.dataset.regionMapTone ?? "accent";
      }

      for (const button of root.querySelectorAll<HTMLButtonElement>("[data-region-map-view-button]")) {
        button.addEventListener("click", () => {
          const viewId = button.dataset.regionMapViewButton;

          if (!viewId) {
            return;
          }

          activateView(root, viewId);
        });
      }

      activateView(root, root.dataset.initialView ?? panels[0]?.dataset.regionMapView ?? "");
    }
  }
</script>
