---
interface Props {
  headline: string;
  body: string;
  tone?: "info" | "alert" | "success";
}

const { headline, body, tone = "info" } = Astro.props;

const icons = {
  info: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`,
  alert: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
  success: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`
};
---

<div class={`plain-english pe-${tone}`} role="note">
  <div class="pe-icon" set:html={icons[tone]} />
  <div class="pe-body">
    <strong class="pe-headline">{headline}</strong>
    <p class="pe-text">{body}</p>
  </div>
</div>

<style>
  .plain-english {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--panel);
    margin-bottom: 1.5rem;
  }
  .pe-icon {
    flex-shrink: 0;
    margin-top: 2px;
  }
  .pe-info .pe-icon { color: var(--accent); }
  .pe-alert .pe-icon { color: var(--accent-3); }
  .pe-success .pe-icon { color: var(--accent-2); }
  .pe-headline {
    display: block;
    font-family: "Sora", sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 0.25rem;
  }
  .pe-text {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
  }
  @media (max-width: 640px) {
    .plain-english { padding: 0.75rem 1rem; }
    .pe-headline { font-size: 0.88rem; }
    .pe-text { font-size: 0.85rem; }
  }
</style>
