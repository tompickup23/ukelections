---
interface Props {
  src: string;
  poster?: string;
  title: string;
  description?: string;
}

const { src, poster, title, description } = Astro.props;
const isYouTube = src.includes("youtube.com") || src.includes("youtu.be");
const youtubeId = isYouTube ? src.match(/(?:v=|youtu\.be\/)([a-zA-Z0-9_-]+)/)?.[1] : null;
---

<figure class="video-embed">
  {description && (
    <div class="video-header">
      <span class="video-badge">Video</span>
      <span class="video-title">{title}</span>
    </div>
  )}
  <div class="video-container">
    {youtubeId ? (
      <iframe
        src={`https://www.youtube-nocookie.com/embed/${youtubeId}?rel=0`}
        title={title}
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      />
    ) : (
      <video
        src={src}
        poster={poster}
        controls
        preload="metadata"
        playsinline
      >
        <track kind="captions" />
      </video>
    )}
  </div>
  {description && <figcaption class="video-caption">{description}</figcaption>}
</figure>

<style>
  .video-embed {
    margin: 0 0 1.5rem;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--panel);
  }
  .video-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
  }
  .video-badge {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    padding: 0.15rem 0.5rem;
    border-radius: 6px;
    background: rgba(6, 182, 212, 0.12);
  }
  .video-title {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--ink-soft);
  }
  .video-container {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 */
  }
  .video-container iframe,
  .video-container video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: #000;
  }
  .video-caption {
    padding: 0.65rem 1rem;
    font-size: 0.82rem;
    color: var(--muted);
    border-top: 1px solid var(--border);
  }
</style>
