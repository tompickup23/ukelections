---
/**
 * Horizontal waterfall chart showing shift-share decomposition.
 * Three bars (national, structural, local) summing to total change.
 */
interface Props {
  total: number;
  national: number;
  structural: number;
  local: number;
  areaName: string;
}

const { total, national, structural, local, areaName } = Astro.props;

const maxAbs = Math.max(Math.abs(national), Math.abs(structural), Math.abs(local), 1);
const barWidth = (val: number) => Math.abs(val) / maxAbs * 100;
const barColor = (val: number) => val < 0 ? "#06b6d4" : "#f59e0b";
---

<figure class="viz-card shift-share-chart">
  <div class="viz-head">
    <h3>Why {areaName} is changing</h3>
    <span class="chip">{total > 0 ? "+" : ""}{total}pp</span>
  </div>
  <div class="ss-bars">
    <div class="ss-row">
      <span class="ss-label">National trend</span>
      <div class="ss-track">
        <div class="ss-bar" style={`width: ${barWidth(national)}%; background: ${barColor(national)}`}></div>
      </div>
      <span class="ss-value">{national > 0 ? "+" : ""}{national}pp</span>
    </div>
    <div class="ss-row">
      <span class="ss-label">Age structure</span>
      <div class="ss-track">
        <div class="ss-bar" style={`width: ${barWidth(structural)}%; background: ${barColor(structural)}`}></div>
      </div>
      <span class="ss-value">{structural > 0 ? "+" : ""}{structural}pp</span>
    </div>
    <div class="ss-row">
      <span class="ss-label">Local migration</span>
      <div class="ss-track">
        <div class="ss-bar" style={`width: ${barWidth(local)}%; background: ${barColor(local)}`}></div>
      </div>
      <span class="ss-value">{local > 0 ? "+" : ""}{local}pp</span>
    </div>
  </div>
  <p class="ss-caption">White British change 2011–2021. Cyan = decline. Amber = growth.</p>
</figure>

<style>
  .ss-bars { display: flex; flex-direction: column; gap: 0.6rem; }
  .ss-row { display: grid; grid-template-columns: 7rem 1fr 3.5rem; align-items: center; gap: 0.5rem; }
  .ss-label { font-size: 0.82rem; color: var(--muted); }
  .ss-track { height: 1.4rem; background: rgba(255,255,255,0.04); border-radius: 4px; overflow: hidden; }
  .ss-bar { height: 100%; border-radius: 4px; min-width: 4px; transition: width 300ms; }
  .ss-value { font-size: 0.8rem; font-weight: 700; font-family: "Sora", sans-serif; text-align: right; }
  .ss-caption { font-size: 0.78rem; color: var(--muted); opacity: 0.6; margin-top: 0.5rem; }
</style>
