---
/**
 * Interactive scenario selector for population projections.
 * Shows a 3×3 grid (fertility × migration) and updates the WBI trajectory chart.
 * Uses pre-computed scenario-summaries.json for fast client-side switching.
 */
interface ScenarioYear {
  wbiPct: number;
  total: number;
}

interface ScenarioData {
  [scenario: string]: {
    [year: string]: ScenarioYear;
  };
}

interface Props {
  areaCode: string;
  areaName: string;
  scenarioData: ScenarioData;
  centralScenario: string;
}

const { areaCode, areaName, scenarioData, centralScenario } = Astro.props;

// Build the 3×3 grid data
const fertilityOptions = [
  { key: "constant", label: "Constant", desc: "Rates stay at current levels" },
  { key: "half_convergence", label: "Half convergence", desc: "Move halfway to national avg" },
  { key: "full_convergence", label: "Full convergence", desc: "Converge to national avg" }
];

const migrationOptions = [
  { key: "low_migration", label: "Low", desc: "~108k/yr" },
  { key: "principal", label: "Principal", desc: "~315k/yr" },
  { key: "high_migration", label: "High", desc: "~476k/yr" }
];

// Get scenario range
const wbi2051Values = Object.entries(scenarioData)
  .map(([, d]) => d["2051"]?.wbiPct)
  .filter((v): v is number => v !== undefined);

const min2051 = Math.min(...wbi2051Values);
const max2051 = Math.max(...wbi2051Values);
const central2051 = scenarioData[centralScenario]?.["2051"]?.wbiPct ?? 0;
const spreadPp = Math.round((max2051 - min2051) * 10) / 10;

// Pre-render central scenario chart data for server-side display
const centralData = scenarioData[centralScenario];
const years = ["2031", "2041", "2051", "2061"].filter(y => centralData?.[y]);
---

<div class="scenario-section" data-area={areaCode} data-central={centralScenario}>
  <h3>Scenario explorer</h3>
  <p class="scenario-range-text">
    Under different assumptions, White British share in {areaName} ranges from
    <strong>{min2051.toFixed(1)}%</strong> to <strong>{max2051.toFixed(1)}%</strong>
    by 2051 — a <strong>{spreadPp}pp spread</strong>.
  </p>

  <!-- 3×3 selector grid -->
  <div class="scenario-grid-wrapper">
    <div class="scenario-grid-label-y">Fertility</div>
    <div class="scenario-grid">
      <!-- Header row: migration labels -->
      <div class="sg-corner"></div>
      {migrationOptions.map(m => (
        <div class="sg-col-header">
          <span class="sg-header-label">{m.label}</span>
          <span class="sg-header-desc">{m.desc}</span>
        </div>
      ))}

      {fertilityOptions.map(f => (
        <>
          <div class="sg-row-header">
            <span class="sg-header-label">{f.label}</span>
            <span class="sg-header-desc">{f.desc}</span>
          </div>
          {migrationOptions.map(m => {
            const key = `${f.key}__${m.key}`;
            const isCentral = key === centralScenario;
            const val = scenarioData[key]?.["2051"]?.wbiPct;
            return (
              <button
                class={`sg-cell ${isCentral ? "sg-cell-central" : ""}`}
                data-scenario={key}
                title={`${f.label} fertility, ${m.label} migration`}
              >
                <span class="sg-cell-value">{val !== undefined ? `${val.toFixed(1)}%` : "—"}</span>
                {isCentral && <span class="sg-cell-badge">Central</span>}
              </button>
            );
          })}
        </>
      ))}
    </div>
    <div class="scenario-grid-label-x">Migration</div>
  </div>

  <!-- Chart area updated by JS -->
  <div class="scenario-chart-area">
    <div class="scenario-chart-label" id={`scenario-label-${areaCode}`}>
      Central scenario: WBI {central2051.toFixed(1)}% by 2051
    </div>
    <svg class="scenario-chart" id={`scenario-chart-${areaCode}`}
         viewBox="0 0 480 180" role="img" aria-label="Scenario projection chart">
      <!-- Rendered by client-side JS -->
    </svg>
  </div>

  <!-- Embed scenario data for JS -->
  <script define:vars={{ areaCode, scenarioData, centralScenario }}>
    (function() {
      const container = document.querySelector(`[data-area="${areaCode}"]`);
      if (!container) return;

      const svg = document.getElementById(`scenario-chart-${areaCode}`);
      const label = document.getElementById(`scenario-label-${areaCode}`);
      const cells = container.querySelectorAll('.sg-cell');
      const allData = scenarioData;
      const W = 480, H = 180;
      const pad = { top: 12, right: 14, bottom: 28, left: 40 };

      function renderChart(scenario) {
        const data = allData[scenario];
        if (!data || !svg) return;

        const years = [2031, 2041, 2051, 2061].filter(y => data[String(y)]);
        const values = years.map(y => data[String(y)].wbiPct);
        if (values.length === 0) return;

        const minY = Math.max(0, Math.min(...values) - 5);
        const maxY = Math.min(100, Math.max(...values) + 5);
        const yRange = Math.max(maxY - minY, 1);
        const xRange = Math.max(years[years.length - 1] - years[0], 1);

        function sx(yr) { return pad.left + ((yr - years[0]) / xRange) * (W - pad.left - pad.right); }
        function sy(v) { return pad.top + (H - pad.top - pad.bottom) - ((v - minY) / yRange) * (H - pad.top - pad.bottom); }

        // Also render central as ghost line
        const centralData = allData[centralScenario];
        const centralVals = years.map(y => centralData?.[String(y)]?.wbiPct).filter(v => v !== undefined);
        let centralPath = '';
        if (scenario !== centralScenario && centralVals.length === years.length) {
          centralPath = years.map((yr, i) => `${i === 0 ? 'M' : 'L'} ${sx(yr).toFixed(1)} ${sy(centralVals[i]).toFixed(1)}`).join(' ');
        }

        const linePath = years.map((yr, i) => `${i === 0 ? 'M' : 'L'} ${sx(yr).toFixed(1)} ${sy(values[i]).toFixed(1)}`).join(' ');
        const endVal = values[values.length - 1];
        const endYr = years[years.length - 1];

        svg.innerHTML = `
          ${[0, 25, 50, 75, 100].filter(t => t >= minY && t <= maxY).map(t => `
            <line x1="${pad.left}" y1="${sy(t).toFixed(1)}" x2="${W - pad.right}" y2="${sy(t).toFixed(1)}"
                  stroke="rgba(255,255,255,0.06)" stroke-dasharray="4 6" />
            <text x="${pad.left - 6}" y="${(sy(t) + 4).toFixed(1)}" text-anchor="end"
                  style="font-size:10px;fill:rgba(255,255,255,0.4);font-family:Sora,sans-serif">${t}</text>
          `).join('')}
          ${centralPath ? `<path d="${centralPath}" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" stroke-dasharray="4 4" />` : ''}
          <path d="${linePath}" fill="none" stroke="#06b6d4" stroke-width="2.5" stroke-linejoin="round" />
          <circle cx="${sx(endYr).toFixed(1)}" cy="${sy(endVal).toFixed(1)}" r="4" fill="#06b6d4" />
          <text x="${(sx(endYr) + 8).toFixed(1)}" y="${(sy(endVal) + 4).toFixed(1)}"
                style="font-size:12px;fill:#06b6d4;font-weight:600;font-family:Sora,sans-serif">${endVal.toFixed(1)}%</text>
          ${years.map(yr => `
            <text x="${sx(yr).toFixed(1)}" y="${H - 6}" text-anchor="middle"
                  style="font-size:10px;fill:rgba(255,255,255,0.5);font-family:Sora,sans-serif">${yr}</text>
          `).join('')}
        `;

        // Update label
        const parts = scenario.split('__');
        const fert = parts[0].replace(/_/g, ' ');
        const mig = parts[1].replace(/_/g, ' ');
        const isCentral = scenario === centralScenario;
        label.innerHTML = isCentral
          ? `Central scenario: WBI ${endVal.toFixed(1)}% by ${endYr}`
          : `${fert} fertility, ${mig}: WBI ${endVal.toFixed(1)}% by ${endYr}`;
      }

      // Initial render
      renderChart(centralScenario);

      // Click handlers
      cells.forEach(cell => {
        cell.addEventListener('click', () => {
          cells.forEach(c => c.classList.remove('sg-cell-active'));
          cell.classList.add('sg-cell-active');
          renderChart(cell.dataset.scenario);
        });
      });

      // Set central as initially active
      const centralCell = container.querySelector(`[data-scenario="${centralScenario}"]`);
      if (centralCell) centralCell.classList.add('sg-cell-active');
    })();
  </script>
</div>

<style>
  .scenario-section { margin-top: 2rem; }
  .scenario-section h3 { font-size: 1.15rem; margin-bottom: 0.5rem; }
  .scenario-range-text { color: var(--muted); font-size: 0.9rem; margin-bottom: 1rem; }
  .scenario-range-text strong { color: var(--text); }

  .scenario-grid-wrapper {
    position: relative;
    margin-bottom: 1.5rem;
  }

  .scenario-grid-label-y {
    position: absolute;
    left: -1.8rem;
    top: 50%;
    transform: rotate(-90deg) translateX(-50%);
    font-size: 0.72rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .scenario-grid-label-x {
    text-align: center;
    font-size: 0.72rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.3rem;
  }

  .scenario-grid {
    display: grid;
    grid-template-columns: auto repeat(3, 1fr);
    gap: 3px;
    margin-left: 0.5rem;
  }

  .sg-corner { }

  .sg-col-header, .sg-row-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.3rem;
    font-size: 0.78rem;
  }

  .sg-header-label { font-weight: 600; color: var(--text); }
  .sg-header-desc { font-size: 0.68rem; color: var(--muted); }

  .sg-row-header {
    text-align: right;
    align-items: flex-end;
    padding-right: 0.5rem;
  }

  .sg-cell {
    position: relative;
    padding: 0.5rem 0.3rem;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 6px;
    background: rgba(255,255,255,0.02);
    cursor: pointer;
    text-align: center;
    transition: all 0.15s;
    font-family: inherit;
    color: inherit;
  }

  .sg-cell:hover {
    background: rgba(6, 182, 212, 0.08);
    border-color: rgba(6, 182, 212, 0.3);
  }

  .sg-cell-active, .sg-cell-active:hover {
    background: rgba(6, 182, 212, 0.15);
    border-color: #06b6d4;
    box-shadow: 0 0 8px rgba(6, 182, 212, 0.2);
  }

  .sg-cell-central {
    border-color: rgba(245, 158, 11, 0.3);
  }

  .sg-cell-value {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .sg-cell-badge {
    position: absolute;
    top: -6px;
    right: -4px;
    font-size: 0.6rem;
    background: rgba(245, 158, 11, 0.8);
    color: #000;
    padding: 1px 4px;
    border-radius: 3px;
    font-weight: 600;
  }

  .scenario-chart-area { margin-top: 0.75rem; }
  .scenario-chart-label {
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 0.3rem;
    min-height: 1.2em;
  }
  .scenario-chart { width: 100%; height: auto; display: block; }

  @media (max-width: 600px) {
    .sg-cell { padding: 0.3rem 0.15rem; }
    .sg-cell-value { font-size: 0.85rem; }
    .sg-header-desc { display: none; }
    .scenario-grid-label-y { display: none; }
  }
</style>
