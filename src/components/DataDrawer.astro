---
interface Props {
  id?: string;
  label?: string;
  title: string;
  summary: string;
  open?: boolean;
}

const { id, label = "Deep dive", title, summary, open = false } = Astro.props;
---

<details id={id} class="section section-anchor data-drawer" open={open}>
  <summary class="data-drawer-summary">
    <div>
      <span class="tiny">{label}</span>
      <h2>{title}</h2>
      <p class="lede">{summary}</p>
    </div>
  </summary>
  <div class="data-drawer-body">
    <slot />
  </div>
</details>

<script>
  const windowWithDrawerFlag = window as Window & { __ukdDataDrawerInit?: boolean };

  if (!windowWithDrawerFlag.__ukdDataDrawerInit) {
    windowWithDrawerFlag.__ukdDataDrawerInit = true;

    const openDrawerForHashTarget = () => {
      if (!window.location.hash) {
        return;
      }

      const target = document.querySelector(window.location.hash);
      const drawer = target?.closest("details.data-drawer");

      if (drawer instanceof HTMLDetailsElement) {
        drawer.open = true;
      }
    };

    window.addEventListener("hashchange", openDrawerForHashTarget);

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", openDrawerForHashTarget, { once: true });
    } else {
      openDrawerForHashTarget();
    }
  }
</script>
