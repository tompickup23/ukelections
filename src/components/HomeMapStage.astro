    };

    const authorityFocusProfiles: Record<string, AuthorityFocusProfile> = {
      E06000063: { biasY: -0.03, minSpanRatio: 0.17, paddingScale: 0.2 },
      E06000064: { biasY: -0.04, minSpanRatio: 0.17, paddingScale: 0.2 },
