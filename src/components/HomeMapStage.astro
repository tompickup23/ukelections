      E08000003: { minSpanRatio: 0.12, paddingScale: 0.2 },
      E08000012: { biasX: -0.02, minSpanRatio: 0.14, paddingScale: 0.2 },
      E08000025: { minSpanRatio: 0.12, paddingScale: 0.2 },
      N09000003: { minSpanRatio: 0.11, paddingScale: 0.18 }
    };

    const subregionRenderProfiles: Record<string, Record<string, SubregionRenderProfile>> = {
      "East Midlands": {
        Nottinghamshire: { labelBiasX: 0.04, labelBiasY: -0.06, focusBiasY: -0.03, minSpanRatio: 0.15, paddingScale: 0.22 },
        Leicestershire: { labelBiasX: -0.02, labelBiasY: 0.1, focusBiasY: 0.05, minSpanRatio: 0.15, paddingScale: 0.21 },
        Derbyshire: { labelBiasX: -0.14, labelBiasY: -0.04, focusBiasX: -0.07, minSpanRatio: 0.14, paddingScale: 0.2 },
