---
import RegionMapExplorer from "./RegionMapExplorer.astro";
import type { PlaceDirectory } from "../lib/place-directory";
import { buildPlaceSubregions } from "../lib/place-subregions";
import type { RegionMapView } from "../lib/region-map-explorer";

interface Props {
  id?: string;
  placeDirectory: PlaceDirectory;
  snapshotDate: string;
  views: RegionMapView[];
}

type HomeMapScopeMeta = {
  scopeId: string;
  scopeKind: "national" | "region" | "subregion" | "place";
  regionName?: string;
  countryName?: string;
  subregionScopeId?: string;
  subregionName?: string;
  eyebrow: string;
  title: string;
  note: string;
};

const { id, placeDirectory, snapshotDate, views } = Astro.props;

const scopeMeta: Record<string, HomeMapScopeMeta> = {
  national: {
    scopeId: "national",
    scopeKind: "national",
    eyebrow: "Place-led asylum accountability",
    title: "Britain first. Then narrow.",
    note: "Pick one region on the map. The deck narrows from Britain to one region to one local authority."
  }
};

const regionPayload = placeDirectory.regions.map((region) => {
  const subregions = buildPlaceSubregions(region);
  const subregionByAreaCode = new Map(
    subregions.flatMap((subregion) => subregion.areaCodes.map((areaCode) => [areaCode, subregion] as const))
  );

  scopeMeta[region.regionName] = {
    scopeId: region.regionName,
    scopeKind: "region",
    regionName: region.regionName,
    countryName: region.countryName,
    eyebrow: `${region.countryName} region`,
    title: region.regionName,
    note: "Choose one authority in this region."
  };

  subregions.forEach((subregion) => {
    scopeMeta[subregion.scopeId] = {
      scopeId: subregion.scopeId,
      scopeKind: "subregion",
      regionName: region.regionName,
      countryName: region.countryName,
      subregionScopeId: subregion.scopeId,
      subregionName: subregion.label,
      eyebrow: `${region.regionName} cluster`,
      title: subregion.label,
      note: `Choose one authority inside ${subregion.label}.`
    };
  });

  const areas = region.areas.map((row) => {
    const subregion = subregionByAreaCode.get(row.area.areaCode);

    scopeMeta[row.area.areaCode] = {
      scopeId: row.area.areaCode,
      scopeKind: "place",
      regionName: region.regionName,
      countryName: region.countryName,
      subregionScopeId: subregion?.scopeId,
      subregionName: subregion?.label,
      eyebrow: `${region.regionName} local preview`,
      title: row.area.areaName,
      note: "Local preview."
    };

    return {
      areaCode: row.area.areaCode,
      areaName: row.area.areaName,
      subregionScopeId: subregion?.scopeId ?? null,
      subregionName: subregion?.label ?? null,
      supportedAsylum: row.area.supportedAsylum,
      supportedAsylumRate: row.area.supportedAsylumRate,
      contingencyAccommodation: row.area.contingencyAccommodation,
      hotelSignalValue: row.hotelSignal === "named" ? 2 : row.hotelSignal === "unnamed" ? 1 : 0,
      hotelSignalLabel:
        row.hotelSignal === "named"
          ? `${row.namedCurrentSiteCount} named current hotel site${row.namedCurrentSiteCount === 1 ? "" : "s"}`
          : row.hotelSignal === "unnamed"
            ? `${row.unnamedSiteCount} unnamed acknowledged hotel site${row.unnamedSiteCount === 1 ? "" : "s"}`
            : "No named current hotel site visible"
    };
  });

  return {
    regionName: region.regionName,
    countryName: region.countryName,
    regionPath: region.regionPath,
    subregions: subregions.map((subregion) => ({
      scopeId: subregion.scopeId,
      label: subregion.label,
      supportedAsylum: subregion.supportedAsylum,
      supportedAsylumRate: subregion.supportedAsylumRate,
      contingencyAccommodation: subregion.contingencyAccommodation,
      hotelSignalValue: subregion.hotelSignalValue,
      hotelSignalLabel: subregion.hotelSignalLabel,
      publicPlaceCount: subregion.publicPlaceCount,
      namedCurrentSiteCount: subregion.namedCurrentSiteCount,
      unnamedSiteCount: subregion.unnamedSiteCount,
      leadAreaCode: subregion.leadArea?.area.areaCode ?? null,
      leadAreaName: subregion.leadArea?.area.areaName ?? null,
      areaCodes: subregion.areaCodes
    })),
    areas
  };
});

const payload = JSON.stringify({
  boundariesUrl: "/place-boundaries.json",
  initialScopeId: "national",
  publicPlaceCount: placeDirectory.publicPlaceCount,
  hotelLinkedPlaceCount: placeDirectory.hotelLinkedPlaceCount,
  scopeMeta,
  regions: regionPayload
});
---

<section class="home-map-stage" data-home-map-stage data-home-map-depth="national" id={id}>
  <script type="application/json" data-home-map-data set:html={payload} is:inline></script>

  <div class="home-map-intro">
    <div class="home-map-topline">
      <div class="chip-row home-map-path">
        <button type="button" class="chip accent" data-home-map-path-root data-home-map-scope-button="national">
          Britain
        </button>
        <button type="button" class="chip" data-home-map-path-region data-home-map-scope-button="" hidden></button>
        <button type="button" class="chip warm" data-home-map-path-group data-home-map-scope-button="" hidden></button>
        <button type="button" class="chip teal" data-home-map-path-area data-home-map-scope-button="" hidden></button>
      </div>
      <div class="home-map-nav">
        <button type="button" class="chip" data-home-map-back disabled aria-label="Zoom out to the previous map view">
          Zoom out
        </button>
        <button type="button" class="chip" data-home-map-forward disabled aria-label="Zoom in to the next map view">
          Zoom in
        </button>
        <span class="chip warm home-map-depth-chip" data-home-map-depth-chip>National lens</span>
      </div>
    </div>
    <div class="home-map-copy">
      <span class="kicker" data-home-map-eyebrow>{scopeMeta.national.eyebrow}</span>
      <h1 data-home-map-title>{scopeMeta.national.title}</h1>
      <p data-home-map-note>{scopeMeta.national.note}</p>
    </div>
    <div class="chip-row home-map-meta" hidden>
      <span class="chip">{snapshotDate} local snapshot</span>
      <span class="chip teal">{placeDirectory.publicPlaceCount.toLocaleString()} public place pages</span>
      <span class="chip accent">
        {placeDirectory.hotelLinkedPlaceCount.toLocaleString()} place pages with hotel evidence
      </span>
    </div>
  </div>

  <div class="home-map-pane is-active" data-home-map-pane="national">
    <RegionMapExplorer
      id="homepage-region-map"
      title="Britain map"
      intro="Select a region to narrow the fixed homepage stage from Britain into one regional authority map."
      views={views}
      compact={true}
      labelMode="selected"
      interactionMode="select"
      showSummary={false}
      legendMode="overlay"
      fitMode="contain"
    />
  </div>

  <section class="home-authority-stage" data-home-authority-stage hidden>
    <article class="region-map-legend is-overlay home-authority-legend" data-home-authority-legend>
      <div class="region-map-legend-top">
        <div class="chip-row">
          <span class="chip accent">Authority map</span>
        </div>
        <div class="region-map-controls" role="toolbar" aria-label="Regional authority map metric">
          <button type="button" class="chip accent is-active" data-home-authority-view="total">
            Total
          </button>
          <button type="button" class="chip" data-home-authority-view="rate">
            Rate
          </button>
          <button type="button" class="chip" data-home-authority-view="hotel">
            Hotel visibility
          </button>
        </div>
      </div>
      <div class="region-map-legend-swatch" data-home-authority-swatch data-tone="accent">
        <span>Lower</span>
        <span>Higher</span>
      </div>
      <div class="region-map-legend-copy">
        <strong data-home-authority-legend-title>Scale first</strong>
        <p class="tiny" data-home-authority-legend-body>
          Use total to see where the largest supported-asylum stock sits before you narrow into one authority.
        </p>
      </div>
    </article>

    <div class="home-authority-canvas">
      <svg
        class="region-map home-authority-map"
        data-home-authority-svg
        viewBox="0 0 620 760"
        preserveAspectRatio="xMidYMid meet"
        role="img"
        aria-label="Regional authority map"
      ></svg>
      <figcaption class="tiny region-map-caption home-authority-caption" data-home-authority-caption>
        Select one authority to update the right-hand deck without leaving the homepage.
      </figcaption>
    </div>

    <section class="home-map-signal-band" data-home-map-signal-band>
      <article class="home-map-signal-card">
        <span class="tiny" data-home-map-signal-label-1>Regions</span>
        <strong data-home-map-signal-value-1>{placeDirectory.regions.length.toLocaleString()}</strong>
        <p data-home-map-signal-meta-1>available for drilldown</p>
      </article>
      <article class="home-map-signal-card">
        <span class="tiny" data-home-map-signal-label-2>Public place pages</span>
        <strong data-home-map-signal-value-2>{placeDirectory.publicPlaceCount.toLocaleString()}</strong>
        <p data-home-map-signal-meta-2>live in the place layer</p>
      </article>
      <article class="home-map-signal-card">
        <span class="tiny" data-home-map-signal-label-3>Hotel-linked places</span>
        <strong data-home-map-signal-value-3>{placeDirectory.hotelLinkedPlaceCount.toLocaleString()}</strong>
        <p data-home-map-signal-meta-3>already carrying hotel evidence</p>
      </article>
    </section>

    <section class="home-map-quick-panel" data-home-map-quick-panel hidden>
      <div class="home-map-quick-head">
        <span class="tiny">Quick picks</span>
        <strong data-home-map-quick-title>Open the highest-pressure authorities next</strong>
      </div>
      <div class="home-map-quick-grid" data-home-map-quick-grid></div>
    </section>

    <aside class="home-map-focus-card" data-home-authority-focus hidden>
      <p class="tiny home-map-focus-kicker" data-home-authority-focus-kicker></p>
      <strong data-home-authority-focus-title></strong>
      <p data-home-authority-focus-body></p>
      <div class="chip-row home-map-focus-meta">
        <span class="chip" data-home-authority-focus-primary hidden></span>
        <span class="chip" data-home-authority-focus-secondary hidden></span>
        <a class="chip accent" data-home-authority-focus-link hidden></a>
      </div>
    </aside>
  </section>
</section>

<script>
  type HomeMapScopeMeta = {
    scopeId: string;
    scopeKind: "national" | "region" | "subregion" | "place";
    regionName?: string;
    countryName?: string;
    subregionScopeId?: string;
    subregionName?: string;
    eyebrow: string;
    title: string;
    note: string;
  };

  type HomeMapSubregionPayload = {
    scopeId: string;
    label: string;
    supportedAsylum: number;
    supportedAsylumRate: number | null;
    contingencyAccommodation: number;
    hotelSignalValue: number;
    hotelSignalLabel: string;
    publicPlaceCount: number;
    namedCurrentSiteCount: number;
    unnamedSiteCount: number;
    leadAreaCode: string | null;
    leadAreaName: string | null;
    areaCodes: string[];
  };

  type HomeMapAreaPayload = {
    areaCode: string;
    areaName: string;
    subregionScopeId: string | null;
    subregionName: string | null;
    supportedAsylum: number;
    supportedAsylumRate: number | null;
    contingencyAccommodation: number;
    hotelSignalValue: number;
    hotelSignalLabel: string;
  };

  type HomeMapRegionPayload = {
    regionName: string;
    countryName: string;
    regionPath: string;
    subregions: HomeMapSubregionPayload[];
    areas: HomeMapAreaPayload[];
  };

  type HomeMapPayload = {
    boundariesUrl: string;
    initialScopeId: string;
    publicPlaceCount: number;
    hotelLinkedPlaceCount: number;
    scopeMeta: Record<string, HomeMapScopeMeta>;
    regions: HomeMapRegionPayload[];
  };

  type BoundaryArea = {
    areaCode: string;
    areaName: string;
    path: string;
    labelX: number;
    labelY: number;
  };

  type BoundaryPayload = {
    width: number;
    height: number;
    regions: Record<string, { countryName: string; areaCount: number; areas: BoundaryArea[] }>;
  };

  type RegionMapChangeDetail = {
    regionName?: string;
    trigger?: string;
  };

  type AuthorityMetricId = "total" | "rate" | "hotel";

  const windowWithHomeMapFlag = window as Window & { __ukdHomeMapInit?: boolean };

  if (!windowWithHomeMapFlag.__ukdHomeMapInit) {
    windowWithHomeMapFlag.__ukdHomeMapInit = true;

    const SVG_NS = "http://www.w3.org/2000/svg";
    const metricConfig: Record<
      AuthorityMetricId,
      { label: string; tone: "accent" | "teal" | "warm"; body: string; title: string }
    > = {
      total: {
        label: "Total",
        tone: "accent",
        title: "Scale first",
        body: "Use total to see where the largest supported-asylum stock sits before you narrow into one authority."
      },
      rate: {
        label: "Rate",
        tone: "teal",
        title: "Intensity first",
        body: "Use rate to find where supported asylum is biting harder relative to the resident population."
      },
      hotel: {
        label: "Hotel visibility",
        tone: "warm",
        title: "Visibility first",
        body: "Use hotel visibility to find where named or acknowledged hotel evidence is already on the public record."
      }
    };

    const formatInteger = (value: number) => value.toLocaleString("en-GB");
    const formatNumber = (value: number) =>
      new Intl.NumberFormat("en-GB", {
        minimumFractionDigits: Number.isInteger(value) ? 0 : 2,
        maximumFractionDigits: Number.isInteger(value) ? 0 : 2
      }).format(value);

    const clampOpacity = (ratio: number) => Math.max(0.18, Math.min(0.84, 0.18 + ratio * 0.58));
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const authorityViewBoxAnimations = new WeakMap<SVGSVGElement, number>();

    type ViewBox = {
      x: number;
      y: number;
      width: number;
      height: number;
    };

    type Bounds = ViewBox;

    const parseViewBox = (raw: string): ViewBox => {
      const parts = raw.split(" ").map((value) => Number.parseFloat(value));

      return {
        x: Number.isFinite(parts[0] ?? NaN) ? parts[0] : 0,
        y: Number.isFinite(parts[1] ?? NaN) ? parts[1] : 0,
        width: Number.isFinite(parts[2] ?? NaN) ? parts[2] : 0,
        height: Number.isFinite(parts[3] ?? NaN) ? parts[3] : 0
      };
    };

    const getCurrentAuthorityViewBox = (svg: SVGSVGElement): ViewBox => {
      const viewBox = svg.viewBox.baseVal;

      if (viewBox && viewBox.width > 0 && viewBox.height > 0) {
        return {
          x: viewBox.x,
          y: viewBox.y,
          width: viewBox.width,
          height: viewBox.height
        };
      }

      return parseViewBox(svg.getAttribute("viewBox") ?? "0 0 620 760");
    };

    const setAuthorityViewBox = (svg: SVGSVGElement, target: ViewBox, durationMs = 0) => {
      if (durationMs <= 0 || prefersReducedMotion) {
        svg.setAttribute("viewBox", `${target.x} ${target.y} ${target.width} ${target.height}`);
        return;
      }

      const activeFrame = authorityViewBoxAnimations.get(svg);

      if (activeFrame !== undefined) {
        window.cancelAnimationFrame(activeFrame);
      }

      const start = getCurrentAuthorityViewBox(svg);
      const deltaX = target.x - start.x;
      const deltaY = target.y - start.y;
      const deltaWidth = target.width - start.width;
      const deltaHeight = target.height - start.height;
      const startTime = performance.now();

      const easeOutCubic = (value: number) => 1 - Math.pow(1 - value, 3);

      const step = (time: number) => {
        const progress = Math.min(1, (time - startTime) / durationMs);
        const eased = easeOutCubic(progress);
        const x = start.x + deltaX * eased;
        const y = start.y + deltaY * eased;
        const width = start.width + deltaWidth * eased;
        const height = start.height + deltaHeight * eased;

        svg.setAttribute("viewBox", `${x} ${y} ${width} ${height}`);

        if (progress < 1) {
          const nextFrame = window.requestAnimationFrame(step);
          authorityViewBoxAnimations.set(svg, nextFrame);
          return;
        }

        authorityViewBoxAnimations.delete(svg);
      };

      const firstFrame = window.requestAnimationFrame(step);
      authorityViewBoxAnimations.set(svg, firstFrame);
    };

    const getFill = (value: number, minValue: number, maxValue: number, tone: "accent" | "teal" | "warm") => {
      const range = Math.max(maxValue - minValue, 1);
      const ratio = (value - minValue) / range;
      const alpha = clampOpacity(ratio);

      if (tone === "teal") {
        return `rgba(78, 228, 195, ${alpha})`;
      }

      if (tone === "warm") {
        return `rgba(255, 139, 97, ${alpha})`;
      }

      return `rgba(125, 211, 252, ${alpha})`;
    };

    const clampNumber = (value: number, minimum: number, maximum: number) =>
      Math.max(minimum, Math.min(maximum, value));

    type AuthorityFocusProfile = {
      biasX?: number;
      biasY?: number;
      maxSpanRatio?: number;
      minSpanRatio?: number;
      paddingMax?: number;
      paddingMin?: number;
      paddingScale?: number;
