---
import SiteHeader from "../components/SiteHeader.astro";
import "../styles/global.css";
import {
  DEFAULT_DESCRIPTION,
  DEFAULT_SOCIAL_IMAGE_PATH,
  SITE_NAME,
  SITE_URL,
  normalisePageTitle,
  type StructuredDataNode
} from "../lib/site";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  structuredData?: StructuredDataNode[];
  bodyClass?: string;
  mainClass?: string;
  hideFooter?: boolean;
}

const {
  title,
  description = DEFAULT_DESCRIPTION,
  image = DEFAULT_SOCIAL_IMAGE_PATH,
  noIndex = false,
  structuredData: pageStructuredData = [],
  bodyClass,
  mainClass,
  hideFooter = false
} = Astro.props;
const siteOrigin = Astro.site ?? new URL(SITE_URL);
const pathname = Astro.url.pathname || "/";
const pageTitle = normalisePageTitle(title);
const canonicalUrl = new URL(pathname, siteOrigin).toString();
const socialImageUrl = /^https?:\/\//.test(image) ? image : new URL(image, siteOrigin).toString();
const robotsContent = noIndex ? "noindex,follow,max-image-preview:large" : "index,follow,max-image-preview:large";
const socialImageMime = socialImageUrl.endsWith(".png")
  ? "image/png"
  : socialImageUrl.endsWith(".webp")
    ? "image/webp"
    : socialImageUrl.endsWith(".svg")
      ? "image/svg+xml"
      : undefined;
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: pageTitle,
    description,
    url: canonicalUrl,
    inLanguage: "en-GB",
    isPartOf: {
      "@id": `${SITE_URL}/#website`
    },
    primaryImageOfPage: {
      "@type": "ImageObject",
      url: socialImageUrl
    }
  },
  ...(pathname === "/"
    ? [
        {
          "@context": "https://schema.org",
          "@type": "WebSite",
          "@id": `${SITE_URL}/#website`,
          url: SITE_URL,
          name: SITE_NAME,
          description: DEFAULT_DESCRIPTION,
          inLanguage: "en-GB",
          publisher: {
            "@id": `${SITE_URL}/#organization`
          }
        },
        {
          "@context": "https://schema.org",
          "@type": "Organization",
          "@id": `${SITE_URL}/#organization`,
          name: SITE_NAME,
          url: SITE_URL,
          logo: {
            "@type": "ImageObject",
            url: new URL("/favicon.svg", siteOrigin).toString()
          }
        }
      ]
    : []),
  ...pageStructuredData
];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#050812" />
    <meta name="color-scheme" content="dark" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    {socialImageMime && <meta property="og:image:type" content={socialImageMime} />}
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${pageTitle} - ukelections.co.uk`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@UKElections" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={`${pageTitle} - ukelections.co.uk`} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://api.postcodes.io; frame-src https://www.youtube-nocookie.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'" />
    <!-- Fonts self-hosted via Fontsource (imported in global.css) -->
    {structuredData.map((item) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <SiteHeader />
    <main id="main-content" class:list={["shell", mainClass]} tabindex="-1">
      <slot />
    </main>
    {!hideFooter && (
      <footer class="shell footer">
        <div class="footer-main">
          Every forecast sourced. Every figure checked. Election data you can interrogate. &middot;
          <a href="/sources/">Sources</a> &middot;
          <a href="/methodology/">Methodology</a> &middot;
          <a href="/findings/">Research</a> &middot;
          <a href="/glossary/">Glossary</a>
        </div>
        <div class="footer-legal-links">
          <a href="/privacy/">Privacy</a> &middot;
          <a href="/terms/">Terms</a> &middot;
          <a href="/accessibility/">Accessibility</a>
        </div>
        <div class="footer-cross-site">
          Demographic context at <a href="https://ukdemographics.co.uk" rel="noopener">ukdemographics.co.uk</a>
        </div>
        <div class="footer-legal">
          ukelections.co.uk is an independent election intelligence project by Tom Pickup. It will use public election results, official candidate data, boundary data, polling, and demographic context.
          Not affiliated with or endorsed by any political party, council, or candidate. No cookies. No tracking. No personal data collected.
          &copy; {new Date().getFullYear()} Tom Pickup. Forecasts are probabilistic estimates, not guarantees.
          <a href="/methodology/">Full methodology &amp; limitations</a>.
        </div>
      </footer>
    )}
  </body>
</html>
