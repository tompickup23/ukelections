---
import SiteHeader from "../components/SiteHeader.astro";
import "../styles/global.css";
import {
  DEFAULT_DESCRIPTION,
  DEFAULT_SOCIAL_IMAGE_PATH,
  SITE_NAME,
  SITE_URL,
  normalisePageTitle,
  type StructuredDataNode
} from "../lib/site";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  structuredData?: StructuredDataNode[];
  mainClass?: string;
}

const {
  title,
  description = DEFAULT_DESCRIPTION,
  image = DEFAULT_SOCIAL_IMAGE_PATH,
  noIndex = false,
  structuredData: pageStructuredData = [],
  mainClass
} = Astro.props;

const siteOrigin = Astro.site ?? new URL(SITE_URL);
const pathname = Astro.url.pathname || "/";
const pageTitle = normalisePageTitle(title);
const canonicalUrl = new URL(pathname, siteOrigin).toString();
const socialImageUrl = /^https?:\/\//.test(image) ? image : new URL(image, siteOrigin).toString();
const robotsContent = noIndex ? "noindex,follow,max-image-preview:large" : "index,follow,max-image-preview:large";
const socialImageMime = socialImageUrl.endsWith(".svg") ? "image/svg+xml" : undefined;
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: pageTitle,
    description,
    url: canonicalUrl,
    inLanguage: "en-GB",
    isPartOf: {
      "@id": `${SITE_URL}/#website`
    },
    primaryImageOfPage: {
      "@type": "ImageObject",
      url: socialImageUrl
    }
  },
  ...(pathname === "/"
    ? [
        {
          "@context": "https://schema.org",
          "@type": "WebSite",
          "@id": `${SITE_URL}/#website`,
          url: SITE_URL,
          name: SITE_NAME,
          description: DEFAULT_DESCRIPTION,
          inLanguage: "en-GB",
          publisher: {
            "@id": `${SITE_URL}/#organization`
          }
        },
        {
          "@context": "https://schema.org",
          "@type": "Organization",
          "@id": `${SITE_URL}/#organization`,
          name: SITE_NAME,
          url: SITE_URL,
          logo: {
            "@type": "ImageObject",
            url: new URL("/favicon.svg", siteOrigin).toString()
          }
        }
      ]
    : []),
  ...pageStructuredData
];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#f7f4ef" />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    {socialImageMime && <meta property="og:image:type" content={socialImageMime} />}
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${pageTitle} - ukelections.co.uk`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    {structuredData.map((item) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <SiteHeader />
    <main id="main-content" class:list={["site-main", mainClass]} tabindex="-1">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <p>
          UK Elections is an independent election intelligence project by Tom Pickup. It is not affiliated
          with any political party, council, candidate, or election authority.
        </p>
        <nav aria-label="Footer">
          <a href="/sources/">Sources</a>
          <a href="/methodology/">Methodology</a>
          <a href="/privacy/">Privacy</a>
          <a href="/terms/">Terms</a>
          <a href="/accessibility/">Accessibility</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
