{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ukelections.co.uk/schemas/boundary_mapping.schema.json",
  "title": "Boundary mapping",
  "type": "object",
  "required": [
    "mapping_id",
    "source_area_id",
    "source_area_code",
    "target_area_id",
    "target_area_code",
    "weight",
    "weight_basis",
    "source_snapshot_id",
    "source_url",
    "review_status"
  ],
  "properties": {
    "mapping_id": { "type": "string", "minLength": 1 },
    "source_area_id": { "type": "string", "minLength": 1 },
    "source_area_code": { "type": "string", "minLength": 1 },
    "target_area_id": { "type": "string", "minLength": 1 },
    "target_area_code": { "type": "string", "minLength": 1 },
    "weight": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
    "weight_basis": { "type": "string", "enum": ["population", "electorate", "lsoa_best_fit", "manual"] },
    "source_snapshot_id": { "type": "string", "minLength": 1 },
    "source_url": { "type": "string", "format": "uri" },
    "review_status": {
      "type": "string",
      "enum": ["unreviewed", "reviewed", "reviewed_with_warnings", "quarantined"]
    }
  },
  "additionalProperties": true
}
