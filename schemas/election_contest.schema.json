{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ukelections.co.uk/schemas/election_contest.schema.json",
  "title": "Election contest",
  "type": "object",
  "required": [
    "contest_id",
    "area_id",
    "election_date",
    "election_type",
    "model_family",
    "voting_system",
    "election_cycle",
    "seats_available",
    "boundary_version_id",
    "source_url"
  ],
  "properties": {
    "contest_id": { "type": "string", "minLength": 1 },
    "area_id": { "type": "string", "minLength": 1 },
    "election_date": { "type": "string", "format": "date" },
    "election_type": {
      "type": "string",
      "enum": [
        "general",
        "local",
        "mayoral",
        "pcc",
        "scottish_parliament",
        "senedd",
        "assembly",
        "by_election",
        "westminster_general",
        "westminster_by_election",
        "borough",
        "district",
        "county",
        "unitary",
        "scottish_parliament_constituency",
        "scottish_parliament_regional_list",
        "senedd_closed_list",
        "senedd_by_election",
        "local_stv"
      ]
    },
    "model_family": {
      "type": "string",
      "enum": [
        "westminster_fptp",
        "local_fptp_borough",
        "local_fptp_county",
        "local_fptp_unitary",
        "local_stv",
        "senedd_closed_list_pr",
        "scottish_ams"
      ]
    },
    "voting_system": {
      "type": "string",
      "enum": ["fptp", "ams", "ams_constituency", "ams_regional_list", "closed_list_pr", "stv"]
    },
    "election_cycle": {
      "type": "string",
      "enum": ["all_out", "thirds", "halves", "single_member", "regional_list"]
    },
    "seats_available": { "type": "integer", "minimum": 1 },
    "boundary_version_id": { "type": "string", "minLength": 1 },
    "source_url": { "type": "string", "format": "uri" }
  },
  "additionalProperties": true
}
