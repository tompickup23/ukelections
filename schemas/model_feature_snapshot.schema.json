{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ukelections.co.uk/schemas/model_feature_snapshot.schema.json",
  "title": "Model feature snapshot",
  "type": "object",
  "required": [
    "feature_snapshot_id",
    "area_code",
    "area_name",
    "boundary_version_id",
    "model_family",
    "as_of",
    "features",
    "provenance",
    "review_status"
  ],
  "properties": {
    "feature_snapshot_id": { "type": "string", "minLength": 1 },
    "area_code": { "type": "string", "minLength": 1 },
    "area_name": { "type": "string", "minLength": 1 },
    "boundary_version_id": { "type": "string", "minLength": 1 },
    "model_family": {
      "type": "string",
      "enum": [
        "westminster_fptp",
        "local_fptp_borough",
        "local_fptp_county",
        "local_fptp_unitary",
        "local_stv",
        "senedd_closed_list_pr",
        "scottish_ams"
      ]
    },
    "as_of": { "type": "string", "format": "date" },
    "features": { "type": "object" },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["field", "source_snapshot_id", "source_url", "notes"],
        "properties": {
          "field": { "type": "string", "minLength": 1 },
          "source_snapshot_id": { "type": "string", "minLength": 1 },
          "source_url": { "type": "string", "format": "uri" },
          "notes": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "review_status": {
      "type": "string",
      "enum": ["unreviewed", "reviewed", "reviewed_with_warnings", "quarantined"]
    }
  },
  "additionalProperties": true
}
